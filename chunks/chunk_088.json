{
 "obj_dw_fcastle_cafe_slash_Other_11_gml_113_0": "* Boss^1, I've realized sticking with you is a safe investment./%",
 "obj_dw_fcastle_cafe_slash_Other_11_gml_118_0": "* I guess \"stick\" was a pun..^1. but I mean it./%",
 "obj_dw_fcastle_cafe_slash_Other_11_gml_150_0": "* Kee kee^1! You recognized me^1, and now..^1. I will follow you!/",
 "obj_dw_fcastle_cafe_slash_Other_11_gml_151_0": "* ..^1. if you can find me!/%",
 "obj_dw_fcastle_cafe_slash_Other_11_gml_158_0": "* I wanted you to find me.../%",
 "obj_dw_fcastle_cafe_slash_Other_11_gml_241_0": "* Nyon!/%",
 "obj_dw_fcastle_cafe_slash_Other_11_gml_249_0": "* Ueueleuleuleue/%",
 "obj_dw_fcastle_cafe_slash_Other_11_gml_277_0": "* Masters^1! Thank you for allowing me to abandon the way of the ninja...!/",
