 "scr_weaponinfo_slash_scr_weaponinfo_gml_400_0": "(Is this a good idea?)",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_401_0": "*zrrt* A-AHH! Scared myself...",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_420_0": "FiberScarf",
