{
 "obj_yellow_trial_manager_slash_Create_0_gml_200_0": "Может, кто покажет&мне, как совершить&это преступление^1? Хи-хи./%",
 "obj_yellow_trial_manager_slash_Create_0_gml_201_0": "Не это преступление./%",
 "obj_yellow_trial_manager_slash_Create_0_gml_202_0": "Возможно, нет./%",
 "obj_yellow_trial_manager_slash_Create_0_gml_204_0": "Ууу, я виновна,&я виновна!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_205_0": "Бирюзовая,^1 прости, что мне&приходится это делать.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_206_0": "Погодите-ка^1. Эта&улика ничего&не доказывает./%",
 "obj_yellow_trial_manager_slash_Create_0_gml_207_0": "Ну же^1, я знаю,&вы можете лучше.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_208_0": "(А можно просто арестовать&её всё равно?)/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_210_0": "Ууу, неверная улика!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_212_0": "Ууу, да! Я украла&ножницы!&Виновна! Виновна!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_213_0": "Этот суд&не об этом!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_214_0": "Ууу^1, Сет говорит...&я невиновна...?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_215_0": "М-может, вы уже&выберете правильную&улику!?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_216_0": "Кто-то должен посадить&этого военного преступника&за решётку!!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_218_0": "Ууу, да! Я&украла ножницы!&Невиновна! Невиновна!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_219_0": "Эй^1, а её&лента не кажется вам&другой...?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_222_0": "Почему вы обвиняете&МЕНЯ, а не&деретесь с НИМИ!?!?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_223_0": "Вините Сета,&вините Сета!&Хи-хи!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_224_0": "Может, не Сета.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_225_0": "Возможно, нет./%",
 "obj_yellow_trial_manager_slash_Create_0_gml_227_0": "Ха! Это&НЕВЕРНАЯ УЛИКА!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_228_0": "Эм^1, то есть...^1&эм..^1. ничего!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_230_0": "Поезд!?&Думаете, я&использовал ПОЕЗД!?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_231_0": "Какие научные&знания можно&почерпнуть из.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_232_0": "..^1. то есть^1, эм,^1&п-право хранить&молчание!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_235_0": "Что?!^2 Вы же знаете,&Зелёный бы&так не поступил!!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_236_0": "Надо винить&Сета!^2 Или меня!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_237_0": "Прости, Зелёный.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_238_0": "Прости^1, Зелёный.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_240_0": "Да ладно, Зелёный!&Мы знаем, это ты!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_241_0": "Неверная улика,&неверная!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_244_0": "Может, он сделал&это случайно./%",
 "obj_yellow_trial_manager_slash_Create_0_gml_245_0": "Вините Жёлтого!&Вините Сета!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_246_0": "Что!^1? Может, я и&правда преступничек.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_247_0": "Ну^1, ну,&Жёлтый^1, это не&ты сделал.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_249_0": "Ха!? Так это я&смазал маслом свою рубашку!?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_250_0": "Вот почему она&такая хрустящая.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_251_0": "Видать, я обжарил её&на сковороде для перекуса.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_252_0": "Ох^1, я знал, что я&преступничек, любящий&горячие закуски.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_253_0": "Жёлтый^1, дорогой.&Ты не сделал&ничего плохого./%",
 "obj_yellow_trial_manager_slash_Create_0_gml_254_0": "Ха!^1? Ох^1, точно,&я ничего такого не делал!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_255_0": "Попробуй снова!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_258_0": "Ты про Акву?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_259_0": "Про меня?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_260_0": "Оо^1, будь ты неладна!!&Синий никогда бы не был&преступником!!^2 Никогда!!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_261_0": "Успокойся^1, Жёлтый.&Они не хотели ничего плохого./%",
 "obj_yellow_trial_manager_slash_Create_0_gml_263_0": ".../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_266_0": "* Вы применили Надоедливого Пса!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_267_0": "* Его запустили, как ракету неизвестной марки!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_268_0": "Что ж^1, вот и&твоя улика.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_269_0": "Вот^1, как насчёт&этих?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_273_0": "* (Как будто улика была верной...)/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_274_0": "* (Как будто преступник был верным...)/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_275_0": "* (Как будто вы совсем не угадали...)/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_279_0": "Видимо, вам&не хватает нужной&улики.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_280_0": "Вот^1, как насчёт&этих?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_1074_0": "\\ER* Этот МОХ был их тюремной едой.../",
 "obj_yellow_trial_manager_slash_Create_0_gml_1075_0": "\\EE* Невиновным не место за решёткой!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_1102_0": "С каких это пор&воры невиновны!?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_1173_0": "Это ПЕРО-ЛЕПЕСТОК...&ты украла его&из святилища!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_1180_0": "\\EC* А..^1. Бирюзовая..^1. это был подарок!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_1183_0": "С каких это пор&оно было её,&чтобы отдавать?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_1224_0": "Жаль^1! Похоже,&снова в тюрьму&для.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_1243_0": "\\Et* Это сделал я^1! Я..^1. всё это была моя идея!!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_1253_0": "Хех.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_1260_0": "\\Ee* Крис^1, Сьюзи^1, мне жаль^1! Закончите это..^1. без меня!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_1310_0": "..^1. неплохо,&Рэйли.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_1318_0": "Но это не приблизило&твоих друзей&ни на шаг к&Тёмному Фонтану!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_1628_0": "Я никогда в жизни&не видела&этот предмет.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_1649_0": "\\ER* Т..^1. тогда...!/%",
