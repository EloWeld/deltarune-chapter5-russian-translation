{
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_152_0": "* (Вот она, вон дует...)/%",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_177_0": "* Я не силач^1. Не обращайся со мной как с одним из твоих предметов./%",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_191_0": "* Я могу быть силачом.../%",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_196_0": "* Я передумал^1. Теперь я готов быть уликой./",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_198_0": "\\EK* Нам это больше не нужно./",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_200_0": "* Значит, всё идёт по ТВОЕМУ расписанию^1, да?/%",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_249_0": "* Зелёный собирался приготовить вкусную горячую закуску^1, но так и не принёс.../",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_251_0": "\\EB* Похоже на улику.../%",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_285_0": "* (Флорадинн добавлен в твои...)/",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_288_0": "* Эй^1, не я^1! Не Я!!/%",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_348_0": "* (...^1? Тут что-то есть.)/",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_349_0": "* (ЖёлтЛоскут добавлен в твои УЛИКИ.)/%",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_373_0": "* (Тлеющее кострище.)/%",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_393_0": "* (Тлеющее кострище.)/%",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_397_0": "* Мои ножницы-украдены.../",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_398_0": "* Украдены-ножницы.../%",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_403_0": "* Эти ножницы — мои-ножницы.../",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_404_0": "* Я их не хочу^1, они краденые./",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_405_0": "* Оставь их как УЛИКУ./%",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_411_0": "* (Шери вернула свои ножницы..^1. но поняла...)/",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_412_0": "* (Что они ей вообще никогда не были нужны...)/%",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_417_0": "* (Она продолжает безуспешно пытаться разрезать воду.)/%",
 "obj_dw_fcastle_sandtrap_slash_Other_11_gml_454_0": "ja",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_68_0": "ja",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_69_0": "ja",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_76_0": "ja",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_133_0": "\\EC* .../%",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_204_0": "\\EL* Сьюзи^1, смотри!/%",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_237_0": "\\EM* .../",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_239_0": "\\EG* .../",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_241_0": "\\EZ* Может, он просто.../%",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_261_0": "\\EH* Крис^1. Нам нужно откопать этого парня^1. Сейчас же./%",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_396_0": "\\EZ* Быстро^1! Крис^1, шляпу!!/%",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_409_0": "\\E9* Хех^1, класс./%",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_428_0": "\\E5* Чёрт^1, стой^1! Жёлтый^1! Он, наверное, там, под этим!/",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_429_0": "\\EH* Ральзей^1, начинай копать!!/%",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_468_0": "ja",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_470_0": "\\E5* Не стой столбом^1, идиот^1! Помоги нам!/",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_472_0": "ja",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_492_0": "ja",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_494_0": "\\E5* Пытаемся откопать тебя из.../%",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_534_0": "\\EB* Секунду./%",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_543_0": "\\E7* Эй^1, чувак^1. Думали, тебя заживо закопало или типа того./",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_545_0": "ja",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_555_0": "ja",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_585_0": "ja",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_601_0": "\\EK* Эм^1, вообще-то^1. Тебе не нужно^1. Это./",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_603_0": "ja",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_608_0": "\\ED* ..^1. смотри./",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_612_0": "\\ES* Мы просто..^1. хотели ключ^1, ладно?/",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_615_0": "\\ET* Ты хороший парень^1. Мы не хотели, чтобы ты сам себя закопал./",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_619_0": "ja",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_621_0": "ja",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_623_0": "ja",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_654_0": "ja",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_713_0": "\\EG* .../%",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_898_0": "\\E5* Жёлтый..^1. Жёлтый, мой дорогой^1, где ты?/",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_899_0": "\\E5* Этот алый цвет..^1. это..^1. это он.../",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_901_0": "\\EE* Слушай^1, мы ничего не знаем про этого./",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_904_0": "\\E2* «Этого»./",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_909_0": "\\EG* Или про других^1. Тоже./",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_911_0": "\\E3* .../%",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_920_0": "\\E0* Слушайте^1, вы трое^1. Честность..^1. это добродетель./",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_921_0": "\\Ey* Итак^1, хотите что-нибудь рассказать мистеру Бабочке?/%",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_969_0": "\\EC* .../%",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_979_0": "\\Ew* Если нет^1, мистер Бабочка очень разозлится.../",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_982_0": "\\ER* ..^1. слушай^1. Произошло недоразумение^1, и.../%",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_1011_0": "ja",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_1022_0": "\\E2* Все вы^1, оставайтесь здесь./%",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_1055_0": "ja",
 "obj_dw_fcastle_sandtrap_slash_Other_12_gml_1103_0": "\\EC* .../%",
 "obj_dw_fcastle_sandtrap_greenaqua_slash_Step_0_gml_73_0": "ja",
 "obj_dw_fcastle_sandtrap_greenaqua_slash_Step_0_gml_75_0": "* (НОЖНИЦЫ добавлены в твои УЛИКИ.)/%",
 "obj_dw_fcastle_sandtrap_shijoke_slash_Step_0_gml_104_0": "* (Кто-нибудь, пожалуйста, помогите мне?)/%",
 "obj_dw_fcastle_sandtrap_shijoke_slash_Step_0_gml_134_0": "Я не знаю,#как я тут оказался.",
 "obj_dw_fcastle_second_diner_slash_Create_0_gml_94_0": "* СЕМЬЯ..^1. СИЛА./%",
 "obj_dw_fcastle_second_diner_slash_Create_0_gml_110_0": "* Леди Бирюзовая^1, отрабатывай свой спиральный танец^1! Спиральный танец!/%",
 "obj_dw_fcastle_second_diner_slash_Create_0_gml_116_0": "* Леди Бирюзовая^1, мы должны сделать тебя чинной и благовоспитанной^1! Принеси гордость Азгору!/%",
 "obj_dw_fcastle_second_diner_slash_Create_0_gml_121_0": "ja",
 "obj_dw_fcastle_second_diner_slash_Step_0_gml_115_0": "Хз, может, это один из твоих крутых секретов?",
 "obj_dw_fcastle_second_diner_slash_Step_0_gml_118_0": "\\E7* Класс^1, Крис^1! Это весело!\\f0",
 "obj_dw_fcastle_second_diner_slash_Step_0_gml_120_0": "\\ED* Если кровь на вкус как копейки.../",
 "obj_dw_fcastle_second_diner_slash_Step_0_gml_121_0": "\\E8* А флауэри-копейки на вкус как кровь Флауэри?/",
 "obj_dw_fcastle_second_diner_slash_Step_0_gml_122_0": "\\EK* ..^1. Ральзей?/",
 "obj_dw_fcastle_second_diner_slash_Step_0_gml_124_0": "\\Eo* П..^1. почему я должен это знать?\\f0/%",
 "obj_dw_fcastle_second_diner_slash_Step_0_gml_127_0": "* (Ты проверил кассу...)/",
 "obj_dw_fcastle_second_diner_slash_Step_0_gml_128_0": "* (В ней только флауэри-копейки^1, которые ничего не стоят.)/%",
 "obj_dw_fcastle_second_diner_slash_Step_0_gml_148_0": "\\E9* (Пффт^1. Крис реально подумал, что это монета.)/",
 "obj_dw_fcastle_second_diner_slash_Step_0_gml_150_0": "\\E2* (Хехех..^1. эм^1, Сьюзи^1, давай не будем смеяться!)/%",
 "obj_dw_fcastle_second_diner_slash_Step_0_gml_153_0": "* (Круглый плоский предмет^1. Не подумав^1, ты коснулся его, чтобы подобрать...)/",
 "obj_dw_fcastle_second_diner_slash_Step_0_gml_154_0": "* (..^1. но это не монета.)/%",
 "obj_dw_fcastle_second_diner_slash_Step_0_gml_172_0": "* (Немного солепёрки.)/%",
 "obj_dw_fcastle_second_diner_slash_Step_0_gml_183_0": "Знаешь,#я был бы сильнее,#если бы не был голоден!",
 "obj_dw_fcastle_seth_encounter_slash_Step_0_gml_512_0": "ja",
 "obj_dw_fcastle_shinobeetle_encounter_slash_Create_0_gml_27_0": "* Л-лично я^1, думаю, пираты круче ниндзя.../%",
 "obj_dw_fcastle_shinobeetle_encounter_slash_Create_0_gml_30_0": "* Сет..^1. хотел, чтобы мы были ниндзя..^1. крались бы незаметно.../",
 "obj_dw_fcastle_shinobeetle_encounter_slash_Create_0_gml_31_0": "* Но^1, Сет также сказал нам^1, орать каждый раз, когда мы появляемся.../%",
 "obj_dw_fcastle_shinobeetle_encounter_slash_Create_0_gml_41_0": "* Смотри на нашу тренировку^1! Тудли-кей-яй REPPA KEN!/%",
 "obj_dw_fcastle_shinobeetle_encounter_slash_Create_0_gml_44_0": "* Я ученик Жёлтого^1. Азгор раньше был мастером ПРАВОСУДИЯ.../",
 "obj_dw_fcastle_shinobeetle_encounter_slash_Create_0_gml_45_0": "* Уверен^1, ему тоже понравятся демонстрации ПРАВОСУДИЯ от Жёлтого!/%",
 "obj_dw_fcastle_shinobeetle_encounter_slash_Step_0_gml_32_0": "* Азгор всегда делится с нами грунтом^1, почвой^1, и суглинком./",
 "obj_dw_fcastle_shinobeetle_encounter_slash_Step_0_gml_33_0": "* Сегодня..^1. мы отплатим тем же^1. Сад из лучшего песка.../",
 "obj_dw_fcastle_shinobeetle_encounter_slash_Step_0_gml_34_0": "* Идеальный деньбют для шоу Ковбоя./%",
 "obj_dw_fcastle_sidepuzzle_slash_Create_0_gml_48_0": "* (Как хитрость для этой головоломки^1, может, тебе стоит встать на Ральзея...)/",
 "obj_dw_fcastle_sidepuzzle_slash_Create_0_gml_49_0": "* (Это «Мальчишеское Лакомство» для такого парня, как он.)/%",
 "obj_dw_fcastle_sidepuzzle_slash_Step_0_gml_115_0": "ja",
