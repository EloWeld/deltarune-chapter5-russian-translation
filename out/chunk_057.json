 "scr_rhythmgame_notechart_slash_scr_rhythmgame_notechart_gml_1527_0": "КОГДА ДЕМОНСКОЕ СЕРДЦЕ ПЛАЧЕТ",
 "scr_rhythmgame_notechart_slash_scr_rhythmgame_notechart_gml_1527_1": "КОГДА СЧАСТ-ЛИ-ВОЕ СЕРДЦЕ [3:УЛЫБ]-АЕТСЯ",
