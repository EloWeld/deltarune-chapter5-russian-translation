 "scr_text_slash_scr_text_gml_4659_0": "%%",
 "scr_text_slash_scr_text_gml_4664_0": "#Отдать#Ральзею",
 "scr_text_slash_scr_text_gml_4665_0": "#Отдать#Сьюзи",
 "scr_text_slash_scr_text_gml_4666_0": "Отдать Ноэлль",
 "scr_text_slash_scr_text_gml_4667_0": "Отдать Бёрдли",
 "scr_text_slash_scr_text_gml_4669_0": "\\EJ* ..^1. ой^1, Крис...? Что это у тебя такое?/",
 "scr_text_slash_scr_text_gml_4670_0": "\\E1* Это что..^1. подарок для кого-то?/",
 "scr_text_slash_scr_text_gml_4671_0": "\\C4 ",
 "scr_text_slash_scr_text_gml_4677_0": "%%",
 "scr_text_slash_scr_text_gml_4683_0": "%%",
 "scr_text_slash_scr_text_gml_4689_0": "%%",
 "scr_text_slash_scr_text_gml_4695_0": "%%",
 "scr_text_slash_scr_text_gml_4701_0": "#У нас#перемирие",
 "scr_text_slash_scr_text_gml_4702_0": "#Она наш#враг",
 "scr_text_slash_scr_text_gml_4703_0": " ",
 "scr_text_slash_scr_text_gml_4704_0": " ",
 "scr_text_slash_scr_text_gml_4706_0": "\\EI* (Крис^1, помоги мне...)/",
 "scr_text_slash_scr_text_gml_4707_0": "\\C2 ",
 "scr_text_slash_scr_text_gml_4713_0": "%%",
 "scr_text_slash_scr_text_gml_4719_0": "%%",
 "scr_text_slash_scr_text_gml_4726_0": "#Да",
 "scr_text_slash_scr_text_gml_4727_0": "#Нет",
 "scr_text_slash_scr_text_gml_4728_0": " ",
 "scr_text_slash_scr_text_gml_4729_0": " ",
 "scr_text_slash_scr_text_gml_4731_0": "* Это раковина в ванной./",
 "scr_text_slash_scr_text_gml_4732_0": "* Откроешь кран?/",
 "scr_text_slash_scr_text_gml_4733_0": "\\C2 ",
 "scr_text_slash_scr_text_gml_4742_0": "%%",
 "scr_text_slash_scr_text_gml_4749_0": "* Тогда кран будет ждать, пока ты не решишь его открыть./%",
 "scr_text_slash_scr_text_gml_4754_0": "#Ноэлль",
 "scr_text_slash_scr_text_gml_4755_0": "#Ральзей",
 "scr_text_slash_scr_text_gml_4756_0": "Тебя",
 "scr_text_slash_scr_text_gml_4757_0": "...",
 "scr_text_slash_scr_text_gml_4759_0": "\\EA* Но допустим, тебе надо было бы^1, э^1, кого-то взять./",
 "scr_text_slash_scr_text_gml_4760_0": "\\E2* Ноэлль..^1. или Ральзея?/",
 "scr_text_slash_scr_text_gml_4761_0": "\\C4 ",
 "scr_text_slash_scr_text_gml_4768_0": "\\EH* Что!? Чего ты это так растерянно говоришь?/",
 "scr_text_slash_scr_text_gml_4769_0": "\\EK* Я ничего странного и не имела в виду./",
 "scr_text_slash_scr_text_gml_4770_0": "\\EK* Знаешь что^1, забей./%",
 "scr_text_slash_scr_text_gml_4777_0": "\\E6* А..^1. а?/",
 "scr_text_slash_scr_text_gml_4778_0": "\\EH* Мастерски увильнул от вопроса^1, придурок!!/",
 "scr_text_slash_scr_text_gml_4785_0": "\\EK* Что^1? Я просто пошутила!!/",
 "scr_text_slash_scr_text_gml_4786_0": "\\EH* Незачем пялиться на меня как чудик!/%",
 "scr_text_slash_scr_text_gml_4792_0": "Я собираюсь#потрогать#сыр",
 "scr_text_slash_scr_text_gml_4793_0": "Я не#трогаю#сыр",
 "scr_text_slash_scr_text_gml_4794_0": " ",
 "scr_text_slash_scr_text_gml_4795_0": " ",
 "scr_text_slash_scr_text_gml_4800_0": "\\E2* Крис.../",
 "scr_text_slash_scr_text_gml_4801_0": "\\E3* Ты же не собираешься трогать этот сыр^1, правда?/",
 "scr_text_slash_scr_text_gml_4802_0": "\\C2 ",
 "scr_text_slash_scr_text_gml_4806_0": "* (На земле лежит сыр.)/",
 "scr_text_slash_scr_text_gml_4807_0": "\\C2 ",
 "scr_text_slash_scr_text_gml_4815_0": "* (Ты погладил сыр, как любимого питомца.)/",
 "scr_text_slash_scr_text_gml_4816_0": "* (Внезапно...!)/%",
 "scr_text_slash_scr_text_gml_4822_0": "%%",
 "scr_text_slash_scr_text_gml_4828_0": "#Да",
 "scr_text_slash_scr_text_gml_4829_0": "#Нет",
 "scr_text_slash_scr_text_gml_4830_0": " ",
 "scr_text_slash_scr_text_gml_4831_0": " ",
 "scr_text_slash_scr_text_gml_4833_0": "* (Похоже, одежда обгрызена. Откусить?)/",
 "scr_text_slash_scr_text_gml_4834_0": "\\C2 ",
 "scr_text_slash_scr_text_gml_4841_0": "... и Сьюзи?",
 "scr_text_slash_scr_text_gml_4843_0": "* (Ты прижался ртом к щеке манекена...)/",
 "scr_text_slash_scr_text_gml_4845_0": "\\EU* К..^1. К...^1. Крис!?!??/",
 "scr_text_slash_scr_text_gml_4847_0": "\\E4* Не парься. На вкус мерзость.\\f0/%",
