 "obj_yellow_enemy_slash_Create_0_gml_53_0": "Чертёж, описывающий,#как переделать рельсы#в крушащую машину.",
 "obj_yellow_enemy_slash_Create_0_gml_54_0": "СапожМасло",
 "obj_yellow_enemy_slash_Create_0_gml_55_0": "Чёрное, непрозрачное масло без#характерного запаха. Используется,#чтобы ковбойские сапоги не скрипели.",
 "obj_yellow_enemy_slash_Create_0_gml_56_0": "Ножницы",
 "obj_yellow_enemy_slash_Create_0_gml_57_0": "Явно украденные ножницы,#которыми легко можно#разрезать ткань.",
 "obj_yellow_enemy_slash_Create_0_gml_58_0": "Пёс",
 "obj_yellow_enemy_slash_Create_0_gml_59_0": "Пёс.",
 "obj_yellow_enemy_slash_Create_0_gml_60_0": "Яйцо",
 "obj_yellow_enemy_slash_Create_0_gml_61_0": "Это улика. Вы поймёте,#доказательством чего она#была, когда это произойдёт.",
 "obj_yellow_enemy_slash_Create_0_gml_258_0": "Дело 1: Флорадинна#расплющили!",
 "obj_yellow_enemy_slash_Create_0_gml_259_0": "Дело 2: Любимую рубашку#Жёлтого испортили и#сделали угольно-чёрной!",
 "obj_yellow_enemy_slash_Create_0_gml_260_0": "Дело 3: У Зелёного#украли платочки!",
 "obj_yellow_enemy_slash_Create_0_gml_261_0": "Дело 4: Супер-#секретные особые лепестки#Жёлтого пропали!",
 "obj_yellow_enemy_slash_Create_0_gml_312_0": "Правосудие",
 "obj_yellow_enemy_slash_Create_0_gml_317_0": "Начать#суд.",
 "obj_yellow_enemy_slash_Create_0_gml_322_0": "Нужно больше#УЛИК!",
 "obj_yellow_enemy_slash_Step_0_gml_97_0": "Усвоил?&Мы упрячем тебя&в тюряжку.../%",
 "obj_yellow_enemy_slash_Step_0_gml_98_0": "Но у них есть&неплохой шанс./%",
 "obj_yellow_enemy_slash_Step_0_gml_99_0": "И наконец засадим&его за решётку./%",
 "obj_yellow_enemy_slash_Step_0_gml_100_0": "У Синего револьвер?&Видать, мне и правда&нравятся стволы.../%",
 "obj_yellow_enemy_slash_Step_0_gml_103_0": "Кто настолько&ботан,&чтобы иметь такое?/%",
 "obj_yellow_enemy_slash_Step_0_gml_104_0": "Пахнет и правда&жутко вкусно.../%",
 "obj_yellow_enemy_slash_Step_0_gml_105_0": "Кстати, я что,&пропустил кровавую&сцену?/%",
 "obj_yellow_enemy_slash_Step_0_gml_106_0": "Я знаю, это вы,&больные&преступнички, натворили!&Признавайтесь!/%",
 "obj_yellow_enemy_slash_Step_0_gml_108_0": "\"Играть в Смэш\"&никогда не бывает правильно./%",
 "obj_yellow_enemy_slash_Step_0_gml_109_0": "Ну... я и правда&хотел попробовать на вкус&эту рубашку./%",
 "obj_yellow_enemy_slash_Step_0_gml_110_0": "Хах! Не знал,&что дырки&это еда.../%",
 "obj_yellow_enemy_slash_Step_0_gml_156_0": "* Пахнет цветами.",
 "obj_yellow_enemy_slash_Step_0_gml_160_0": "* Вы чувствуете странную нехватку УЛИК.",
 "obj_yellow_enemy_slash_Step_0_gml_164_0": "* Суд готов начаться!&* Используйте ДЕЙСТВИЕ ПРАВОСУДИЕ Жёлтого, чтобы начать!",
 "obj_yellow_enemy_slash_Step_0_gml_171_0": "* Сет нервно поглядывает на книги...",
 "obj_yellow_enemy_slash_Step_0_gml_175_0": "* Зелёный демонстративно смазывает маслом сковороду для попкорна...",
 "obj_yellow_enemy_slash_Step_0_gml_179_0": "* Бирюзовая нарочито смеётся над тем, какая красная у неё лента.",
 "obj_yellow_enemy_slash_Step_0_gml_183_0": "* Синий тоскливо смотрит на нитку и вздыхает.",
 "obj_yellow_enemy_slash_Step_0_gml_210_0": "* ЙЕЛЛОУ - AT \\I0 DF \\I1&Ковбой со своим особым&представлением о правосудии./",
 "obj_yellow_enemy_slash_Step_0_gml_211_0": "* БЛЮ - AT \\I2 DF \\I3&Танцовщица, которая верит, что любовь&неотъемлема от жизни./%",
 "obj_yellow_enemy_slash_Step_0_gml_226_0": "* Вы начали суд!/%",
 "obj_yellow_enemy_slash_Step_0_gml_304_0": "Излагай своё дело, потерпевшай!/%",
 "obj_yellow_enemy_slash_Step_0_gml_305_0": "Меня расплющили^3&без разрешения./%",
 "obj_yellow_enemy_slash_Step_0_gml_306_0": "Но это норм./%",
 "obj_yellow_enemy_slash_Step_0_gml_308_0": "КРУТО И НЕЗАКОННО!!!^3&Какие преступнички&могли такое совершить!!^2&Найдите их!!/%",
 "obj_yellow_enemy_slash_Step_0_gml_316_0": "На этот раз потерпевшая&буду я!/%",
 "obj_yellow_enemy_slash_Step_0_gml_317_0": "Мою самую любимую&самую жёлтую рубашку&взяли да&испортили!/%",
 "obj_yellow_enemy_slash_Step_0_gml_318_0": "Половина её&вся чёрная&и вонючая!/%",
 "obj_yellow_enemy_slash_Step_0_gml_319_0": "Какой больной&преступничек портит&мужскую рубашку!?^2&Найдите их!/%",
 "obj_yellow_enemy_slash_Step_0_gml_347_0": "Зелёный, излагай&своё дело!!/%",
 "obj_yellow_enemy_slash_Step_0_gml_364_0": "Воришка, значит!?^2&Лучше вам найти их!!/%",
 "obj_yellow_enemy_slash_Step_0_gml_372_0": "Что!?^1 Я снова потерпевшая!?^1&Мои самые секретные лепестки&УКРАЛИ?!/%",
 "obj_yellow_enemy_slash_Step_0_gml_375_0": "Как это возможно!?&Я никому&про них не говорила!/%",
 "obj_yellow_enemy_slash_Step_0_gml_378_0": "Они были для кого-то&ОСОБЕННОГО... ррррггххх!!/%",
 "obj_yellow_enemy_slash_Step_0_gml_381_0": "Я НИКОГДА НЕ ПРОЩУ&того, кто это сделал!!^1&НИКОГДА!!/%",
 "obj_yellow_enemy_slash_Step_0_gml_445_0": "* БЛЮ наслала ЦЕЛЕБНЫЙ ДОЖДЬ на ЙЕЛЛОУ!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_14_0": "УЛИКИ:#",
 "obj_yellow_trial_manager_slash_Create_0_gml_15_0": "Н/Д",
 "obj_yellow_trial_manager_slash_Create_0_gml_126_0": "Хи-хи!&Это я сделала!&Я это сделала!",
 "obj_yellow_trial_manager_slash_Create_0_gml_127_0": "Я?!^2 Я просто...^2&читал книгу! Ха!",
 "obj_yellow_trial_manager_slash_Create_0_gml_129_0": "Может, это было,&чтобы сохранить его?",
 "obj_yellow_trial_manager_slash_Create_0_gml_130_0": "Под моим сапогом&ничего нет.",
 "obj_yellow_trial_manager_slash_Create_0_gml_133_0": "Хи-хи!&Гори, гори!",
 "obj_yellow_trial_manager_slash_Create_0_gml_134_0": "Я читал&книгу при свете лампы!",
 "obj_yellow_trial_manager_slash_Create_0_gml_136_0": "Это было нарочно?",
 "obj_yellow_trial_manager_slash_Create_0_gml_137_0": "Кто тут врун!?",
 "obj_yellow_trial_manager_slash_Create_0_gml_140_0": "Это была я!! Я убила&платочки&кровью!!",
 "obj_yellow_trial_manager_slash_Create_0_gml_141_0": "Есть кто-то&кроме&Бирюзовой?",
 "obj_yellow_trial_manager_slash_Create_0_gml_143_0": "Была ли другая&причина для этого?",
 "obj_yellow_trial_manager_slash_Create_0_gml_144_0": "Очень опасно.",
 "obj_yellow_trial_manager_slash_Create_0_gml_147_0": "Хи-хи, я не смогла&их найти. Как жаль.",
 "obj_yellow_trial_manager_slash_Create_0_gml_148_0": "Ух ты, интересно,&кто бы это мог быть.",
 "obj_yellow_trial_manager_slash_Create_0_gml_150_0": "...",
 "obj_yellow_trial_manager_slash_Create_0_gml_151_0": "Признавайтесь, вы трое!&Это вы их взяли!!&Я знаю точно!!",
 "obj_yellow_trial_manager_slash_Create_0_gml_160_0": "Ннрг..^1. какие...&какие у вас доказательства!?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_161_0": "Сет...^2 можно нам взглянуть&внутрь&твоей книги?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_162_0": "..^1. там случайно нет&засушенных цветочных&лепестков внутри?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_163_0": "..^1. Я.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_164_0": "Я признаюсь!!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_165_0": "Я хотел попробовать&засушивать цветы!!&Слышал, это&научно!!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_166_0": "Отличная работа^1, Синий!!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_167_0": "Что ж^1, вы, ребята, доказали,&что одно преступление не ваше.&А что насчёт остальных!?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_170_0": "Что!?^1 Зелёный, ты&хотел сделать попкорн.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_171_0": "И ты перепутала&рубашку с кукурузным узором&с настоящей кукурузой!?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_172_0": "Оо^1, получилось?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_173_0": "Ага^1, получилось?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_174_0": "Нет^1, идиоты!&Жёлтый^1, твоя рубашка&сгорела дотла!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_175_0": "Ох^1, Зелёный^1. Я знаю, ты&не хотел ничего плохого./%",
 "obj_yellow_trial_manager_slash_Create_0_gml_176_0": "Но правосудие&есть правосудие.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_179_0": "Да, это была я!!&Я убила&платочки!!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_180_0": "Это была не ты, Бирюзовая.^1&Ты сейчас.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_181_0": "Носишь их&прямо сейчас!!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_182_0": "Да^1, я хотела сделать&красные ленты!^1&Один цвет — скучно!!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_183_0": "Ещё я хотела&устроить жестокую&сцену преступления!!&(Пищевым красителем)/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_184_0": "Молодец^1, Бирюзовая.&Теперь я тебя накажу./%",
 "obj_yellow_trial_manager_slash_Create_0_gml_185_0": "Ураааа!!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_188_0": "Б... Синий!?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_189_0": "Ты обвиняешь БЛЮ&в том, что она взяла&нечто настолько особенное?!/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_190_0": "Ну^1, я тебе щас,&я тебе.../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_191_0": "..^1. Жёлтый./%",
 "obj_yellow_trial_manager_slash_Create_0_gml_192_0": "Что^1, Синий?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_193_0": ".../%",
 "obj_yellow_trial_manager_slash_Create_0_gml_194_0": "Это была я./%",
 "obj_yellow_trial_manager_slash_Create_0_gml_195_0": "БЛЮ!?/%",
 "obj_yellow_trial_manager_slash_Create_0_gml_199_0": "Это не она.^2&Но можно её&всё равно арестовать?/%"
}