{
 "obj_trashy_trio_slash_Create_0_gml_291_0": "Эй, эй, ЭЙ!/%",
 "obj_trashy_trio_slash_Create_0_gml_292_0": "Мне ПОКАЗАЛОСЬ&что кто-то&неправильно использует&мотив БАТТАТ!!/%",
 "obj_trashy_trio_slash_Create_0_gml_293_0": "Что это ещё&за самое&популярное трио!?/%",
 "obj_trashy_trio_slash_Create_0_gml_295_0": "Ну, эм.../%",
 "obj_trashy_trio_slash_Create_0_gml_297_0": "Взять их,&парни!!!/%",
 "obj_trashy_trio_slash_Create_0_gml_299_0": "Ну, похоже&бой&окончен!^1&Увидимся!/%",
 "obj_trashy_trio_slash_Create_0_gml_301_0": "Мы точно показали&тому трио, да,&босс!?/%",
 "obj_trashy_trio_slash_Create_0_gml_303_0": "Эм,^1 кто-то&сказал.../%",
 "obj_trashy_trio_slash_Create_0_gml_304_0": "«Трио»?/%",
 "obj_trashy_trio_slash_Create_0_gml_306_0": "Чт.../%",
 "obj_trashy_trio_slash_Create_0_gml_308_0": "Потому что если&вы тройка,&нам придётся&вас остановить.../%",
 "obj_trashy_trio_slash_Create_0_gml_310_0": "И я поассистирую./%",
 "obj_trashy_trio_slash_Create_0_gml_312_0": "Кажется...^2&мне нужно&побыть одному./%",
 "obj_trashy_trio_slash_Create_0_gml_314_0": "Мне тоже./%",
 "obj_trashy_trio_slash_Create_0_gml_315_0": "Да,&мне тоже./%",
 "obj_trashy_trio_slash_Create_0_gml_316_0": "Ага, аналогично./%",
 "obj_trashy_trio_slash_Create_0_gml_317_0": ":)/%",
 "obj_trashy_trio_slash_Create_0_gml_319_0": ".../%",
 "obj_trashy_trio_slash_Create_0_gml_320_0": "Да будет сие&зваться «Ничьей»./%",
 "obj_flowery_enemy_slash_Step_0_gml_763_0": "\\EA* Крис... зажми&~1&чтобы зарядить.../",
 "obj_flowery_enemy_slash_Step_0_gml_765_0": "\\EI* Нажми кнопку для короткого рывка, или удерживай, чтобы пролететь чуть дальше!/",
 "obj_flowery_enemy_slash_Step_0_gml_1848_0": "Что?^1 Опять&обвиняешь&меня?/%",
 "obj_flowery_enemy_slash_Step_0_gml_1873_0": "Если хочешь&«поверить»&что всё может измениться.../%",
 "obj_flowery_enemy_slash_Step_0_gml_1874_0": "Докажи это&на своей стороне,&посыпка./%",
 "scr_monstersetup_slash_scr_monstersetup_gml_2549_0": "Трио Мусорников",
 "scr_monstersetup_slash_scr_monstersetup_gml_2593_0": "Пример",
 "scr_encountersetup_slash_scr_encountersetup_gml_1263_0_b": "* Самое популярное трио в мире!",
 "scr_encountersetup_slash_scr_encountersetup_gml_1272_0": "...",
 "obj_flowery_enemy_slash_Step_0_gml_2725_0": "* (Сьюзи больше не может СРАЖАТЬСЯ.)/%",
 "obj_fusionmenu_slash_Step_0_gml_150_0_b": "Трио Мусорников",
 "obj_fusionmenu_slash_Step_0_gml_156_0": "Нас слишком долго игнорировали!#Пора появиться новому самому популярному трио в городе!",
 "obj_fusionmenu_slash_Step_0_gml_163_0_b": "Нет",
 "scr_text_slash_scr_text_gml_7856_0": "* ..^1. ну^1, я бы хотел попросить тебя подраться^1, босс, но похоже.../",
 "scr_text_slash_scr_text_gml_7857_0_b": "* ..^1. ты пока не ЗАВЕРБОВАЛ(а) всех./",
 "scr_text_slash_scr_text_gml_7858_0": "* У одного из наших парней есть моральные возражения на этот счёт. Извини^1, босс./%",
 "scr_text_slash_scr_text_gml_7871_0": "* Сегодня без боёв^1, босс. Сегодня только миротворцы./%",
 "obj_overworldc_slash_Step_0_gml_101_0": "* (Не смог(ла).)/%",
 "obj_trashy_trio_slash_Create_0_gml_526_0": "* Сьюзи вылизывает пакет от чипсов дочиста!",
 "obj_trashy_trio_slash_Create_0_gml_527_0": "* Сьюзи делает большооой растяг!",
 "obj_trashy_trio_slash_Create_0_gml_528_0": "* Сьюзи ведёт мяч!",
 "obj_trashy_trio_slash_Create_0_gml_530_0": "* Ральзей отмывает пакет из-под молока!",
 "obj_trashy_trio_slash_Create_0_gml_531_0": "* Ральзей слегка взлетает!",
 "obj_trashy_trio_slash_Create_0_gml_532_0": "* Ральзей промахивается со штрафного!",
 "obj_dw_pink_encounter_slash_Step_0_gml_799_0": "\\E4* Я..^1. я чувствую..^1. единство!/",
 "obj_dw_pink_encounter_slash_Step_0_gml_800_0": "\\EC* Спасибо вам^1, вы трое^1! Благодаря вам.../",
 "obj_dw_pink_encounter_slash_Step_0_gml_801_0_b": "\\E4* Мы наконец можем быть..^1. в гармонии..^1. навсегда!/%",
 "obj_dw_pink_encounter_slash_Step_0_gml_808_0": "\\Ed* ..^1. ну.../",
 "obj_dw_pink_encounter_slash_Step_0_gml_810_0": "\\ED* Есть ещё..^1. Тёмный Фонтан^1, но.../%",
 "obj_dw_pink_encounter_slash_Step_0_gml_817_0": "\\EF* П-погодите.../",
 "obj_dw_pink_encounter_slash_Step_0_gml_818_0": "\\EF* Погодите!/",
 "obj_dw_pink_encounter_slash_Step_0_gml_821_0": "\\EF* ПОГОДИТЕ!!!/%",
 "obj_flowery_enemy_slash_Create_0_gml_127_0": "\\EE* (Крис! Нажми и отпусти&~1, чтобы рвануть!&Простое нажатие тоже сработает!)",
 "obj_npc_dojo_slash_Step_0_gml_69_0": "* Ты^1, эм..^1. победил(а).../",
 "obj_npc_dojo_slash_Step_0_gml_70_0": "* .../",
 "obj_npc_dojo_slash_Step_0_gml_71_0": "* Надеюсь, тебе было весело^1, босс./%",
 "obj_npc_room_slash_Other_10_gml_251_0": "* Нуберт драматично стрижёт волосы, символизируя новую главу в своей жизни.../%",
 "obj_pink_enemy_slash_Step_0_gml_795_0": "* Ты флиртовал(а) отчаянно!",
 "obj_town_church_rudy_slash_Step_0_gml_103_0": "\\E2* Эй^1, не обращай на меня внимания^1, сладенький^1! У тебя есть друзья!/",
 "obj_town_church_rudy_slash_Step_0_gml_104_0": "\\E7* А я^1, я разберусь тут наверху!/",
 "obj_trashy_trio_slash_Create_0_gml_494_0": "Нас троих&слишком долго&игнорировали...!/%",
 "obj_trashy_trio_slash_Create_0_gml_495_0": "Пора тебе&увидеть нашу истинную&силу.../%",
 "obj_trashy_trio_slash_Create_0_gml_496_0": "... как самое&популярное трио&в городе!!/%",
 "obj_trashy_trio_slash_Create_0_gml_531_0_b": "Потому что если&вы тройка/%",
 "obj_trashy_trio_slash_Create_0_gml_532_0_b": "нам придётся&вас остановить.../%",
 "scr_armorinfo_slash_scr_armorinfo_gml_871_0": "Навык20%",
 "scr_text_slash_scr_text_gml_7848_0": "* Босс^1! У меня для тебя есть бой...!/",
 "scr_text_slash_scr_text_gml_7849_0": "* ..^1. но^1, тебе нужно быть трио./",
 "scr_text_slash_scr_text_gml_7850_0_b": "* Тащи сюда эту девчонку Сьюзи!/%",
 "scr_text_slash_scr_text_gml_7872_0": "* Босс^1! Ты подрался со всеми, кто у нас был сегодня.../",
 "scr_text_slash_scr_text_gml_7873_0": "* Ну..^1. я тоже подумывал^1, о трио^1, но.../",
 "scr_text_slash_scr_text_gml_7874_0_b": "* Может, сейчас это не лучшая идея./%",
 "obj_orange_green_controller_slash_Step_0_gml_966_0": "* ЗЕЛЁНАЯ применила ЛЕЧЕБНОЕ ЯЙЦО на себя!/%",
 "obj_orange_green_controller_slash_Step_0_gml_976_0": "* ЗЕЛЁНАЯ применила ЛЕЧЕБНОЕ ЯЙЦО на ОРАНЖЕВУЮ!/%",
