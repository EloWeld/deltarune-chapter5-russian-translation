{
 "scr_text_slash_scr_text_gml_6993_0": "#Особняк",
 "scr_text_slash_scr_text_gml_6994_0": "#Кибер-поле",
 "scr_text_slash_scr_text_gml_6995_0": "Мусорная зона",
 "scr_text_slash_scr_text_gml_6996_0": "Отмена",
 "scr_text_slash_scr_text_gml_6999_0": "* (Это дверь.^1)&* (Куда ты пойдёшь?)//",
 "scr_text_slash_scr_text_gml_7026_0": "* (Удивительно^1, но ты уже там.)/%",
 "scr_text_slash_scr_text_gml_7030_0": "* (Дверь открылась...)/%",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_2_0": " ",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_11_0": " ",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_12_0": " ",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_13_0": " ",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_14_0": " ",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_15_0": " ",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_39_0": "... у тебя МЕЧ!?",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_42_0": "(На нём следы зубов...)",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_64_0": "Он... приятно пахнет...",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_86_0": "А? Нет, мне не холодно.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_105_0": "ОружиеВсех",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_106_0": "Всем оно пришлось впору.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_107_0": "Эээ... ладно.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_108_0": "Сидит идеально!",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_109_0": "Ч... что это?",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_132_0": "(Довольно круто...)",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_154_0": "(В-вау, какая мощь...)",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_176_0": "...? Оно мне улыбнулось?",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_194_0": "Трилистник",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_195_0": "Замшелая рапира с эмблемой клевера.#Увеличивает находки $ на 5%.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_196_0": "Эта безвкусица? Нет!",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_198_0": "Ладно! ...? В смысле — неиспользуемый!?",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_220_0": "Ай! ... вообще-то приятно",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_242_0": "Х-хватит меня им укрывать!",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_260_0": "КривойМеч",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_261_0": "Странный клинок",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_262_0": "... эмм, выглядит плохо.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_263_0": "Он словно спираль.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_264_0": "Он... немного пугает...",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_282_0": "СнежКольцо",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_283_0": "Кольцо с эмблемой#снежинки",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_284_0": "Пахнет Ноэлль",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_285_0": "Ты что... делаешь предложение?",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_286_0": "(Слава богу...)",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_305_0": "ТернКольцо",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_306_0": "Носитель получает урон от боли#Снижает расход ТП на ледяные заклинания",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_307_0": "Орудие пытки?",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_308_0": "...",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_309_0": " ",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_328_0": "ПрыгКлинок",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_329_0": "Розовая сабля с резиновым клинком.#Слабая, но повышает защиту.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_330_0": "Это что, резина?",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_331_0": "Мягкий и упругий!",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_332_0": "Х-хватит меня им лупить!",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_351_0": "БодрШарф",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_352_0": "Шарф с яркими мотивирующими#картинками. Больше ТП с критов.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_353_0": "Смайлики? Фу.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_354_0": "Ты сможешь!",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_355_0": "Вот ЭТО безвкусный шарф! Фаха!",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_374_0": "МехаСабля",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_375_0": "Клинок выдвигается при нажатии на рукоять.#ЧА-ЧК!",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_376_0": "*чк чк чк чк* Не-а.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_377_0": "Ты бы круто смотрелся с ней, Крис!",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_378_0": "*чк* А-АЙ! Сам себя напугал...",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_397_0": "АвтоТопор",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_398_0": "Не забудь зарядить его,#воткнув в розетку.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_399_0": "*звуки бензопилы* Хахаха!!",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_400_0": "(Это хорошая идея?)",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_401_0": "*зррт* А-АЙ! Сам себя напугал...",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_420_0": "ФибрШарф",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_421_0": "Шарф из мягкой микрофибры.#Баланс атаки и магии.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_422_0": "(Мягкий...)",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_423_0": "Ой! Моя шерсть наэлектризовалась!",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_424_0": "Конечно, я... а? Это оружие?",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_443_0": "Раггер2",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_444_0": "Колючий и жёсткий шарф.#Хуже лечение, лучше атака.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_445_0": "Это по части Ральзея.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_446_0": "Я колючий принц!",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_447_0": "(Похоже на бороду Санты?)",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_467_0": "СломМеч",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_468_0": "Забракованный меч, разрубленный на 2 части.#Даже тебе его не надеть...",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_469_0": "... это мусор.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_470_0": "Может, починим его...?",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_471_0": "(З... зачем давать это мне?)",
 "obj_rudinnranger_slash_Step_0_gml_205_0": "* Сьюзи демонстративно НЕ ПОХВАЛИЛА врага!/",
 "scr_text_slash_scr_text_gml_7350_0": "* (Это коробка, полная бубликов. Взять один?)/",
 "DEVICE_FAILURE_slash_Create_0_gml_12_0": "СМЕРТЬ",
 "DEVICE_FAILURE_slash_Step_0_gml_39_0": "  Ну же, это всё^1,& на что ты способен!?/",
 "DEVICE_FAILURE_slash_Step_0_gml_40_0": "  Крис^1,&  вставай...!/%",
 "DEVICE_FAILURE_slash_Step_0_gml_47_0": "  Это не&  твоя судьба...!/",
 "DEVICE_FAILURE_slash_Step_0_gml_48_0": "  Пожалуйста^1,&  не сдавайся!/%",
 "DEVICE_FAILURE_slash_Step_0_gml_103_0_b": "ПРОДОЛЖИТЬ",
 "DEVICE_FAILURE_slash_Step_0_gml_104_0": "СДАТЬСЯ",
 "DEVICE_FAILURE_slash_Step_0_gml_172_0": "ТЬМА",
 "DEVICE_MENU_slash_Create_0_gml_8_0": "КОНТАКТ",
 "DEVICE_MENU_slash_Create_0_gml_17_0": "DELTARUNE",
 "DEVICE_MENU_slash_Create_0_gml_97_0": "[ПУСТО]",
 "DEVICE_MENU_slash_Draw_0_gml_189_0": "ОТМЕНА",
 "DEVICE_MENU_slash_Draw_0_gml_190_0": "Отмена",
 "DEVICE_MENU_slash_Draw_0_gml_199_0": "КОПИЯ",
 "DEVICE_MENU_slash_Draw_0_gml_200_0": "СТЕРЕТЬ",
 "DEVICE_MENU_slash_Draw_0_gml_201_0": "Копия",
 "DEVICE_MENU_slash_Draw_0_gml_201_1": "Стереть",
 "DEVICE_MENU_slash_Step_0_gml_105_0": "[ПУСТО]",
 "obj_ch2_room_town_hospital_slash_Step_0_gml_68_0": "\\E2* Серебряный Дрейк^1, значит? Что-то новенькое./",
 "obj_ch2_room_town_hospital_slash_Step_0_gml_69_0_b": "\\E3* Ладно^1, какой план^1, милая?/",
 "obj_ch2_room_town_hospital_slash_Step_0_gml_71_0": "\\E8* Хмм..^1. может, попробуем.../",
 "obj_ch2_room_town_hospital_slash_Step_0_gml_72_0_b": "\\E4* Ледошок?/",
 "obj_ch2_room_town_hospital_slash_Step_0_gml_74_0_b": "\\E5* Лёд по боссу Ледяного дворца?/",
 "obj_ch2_room_town_hospital_slash_Step_0_gml_75_0": "\\E4* Может, лучше попробуешь Огнешок или вроде того?/%",
 "obj_ch2_room_town_hospital_slash_Step_0_gml_83_0_b": "\\E2* А-а? Да^1, ты прав./",
 "obj_ch2_room_town_hospital_slash_Step_0_gml_85_0": "\\E7* Слушай^1, может, дашь мне немного поуправлять?/%",
 "obj_ch2_room_town_hospital_slash_Step_0_gml_94_0_b": "\\E2* Н-нет^1! Я..^1. сама поуправляю./",
 "obj_ch2_room_town_hospital_slash_Step_0_gml_96_0": "\\E2* Не в твоём духе не отдавать джойстик^1, милая./",
 "obj_ch2_room_town_hospital_slash_Step_0_gml_97_0_b": "\\E4* Ты хорошо себя чувствуешь?/%",
 "obj_ch2_room_town_hospital_slash_Step_0_gml_104_0": "\\E3* А? Я? Конечно^1! Я в порядке^1, пап.../%",
 "obj_ch2_room_town_hospital_slash_Step_0_gml_111_0": "\\Ee* Я просто.../%",
 "obj_ch2_room_town_hospital_slash_Step_0_gml_118_0": "\\E8* Я уснула в библиотеке^1, и.../",
 "obj_ch2_room_town_hospital_slash_Step_0_gml_119_0": "\\E4* ..^1. знаешь^1, просто приснился странный сон. Хаха./",
 "obj_ch2_room_town_hospital_slash_Step_0_gml_121_0_b": "\\E1* Ноэлль.../",
 "obj_ch2_room_town_hospital_slash_Step_0_gml_122_0": "\\E2* Я так и знал, что этот птицемозг тебя усыпит^1! Хаха!/",
 "obj_ch2_room_town_hospital_slash_Step_0_gml_123_0_b": "\\E3* Что он сделал? Начал читать лекцию про свою теорему.../",
 "obj_ch2_room_town_hospital_slash_Step_0_gml_124_0": "\\E7* О неравенстве в детских файтингах?/%"
}
