 "scr_itemnamelist_slash_scr_itemnamelist_gml_168_0": "Шикакола",
 "scr_itemuse_slash_scr_itemuse_gml_717_0": "Ай. Это «пунш», тупица.",
 "scr_itemuse_slash_scr_itemuse_gml_718_0": "У него есть «удар»!",
 "scr_itemuse_slash_scr_itemuse_gml_719_0": "Не смешать бы с жёлтым?",
 "scr_itemuse_slash_scr_itemuse_gml_729_0": "Почему мы не едим пули почаще?",
