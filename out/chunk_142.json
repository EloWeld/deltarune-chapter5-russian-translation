{
 "scr_text_slash_scr_text_gml_7908_0": "Эм?",
 "scr_text_slash_scr_text_gml_7913_0": "Вкуса... больше нет.",
 "scr_text_slash_scr_text_gml_7918_0": "* ~1 использовал(а) ГНИЛОЙЧАЙ!/%",
 "scr_text_slash_scr_text_gml_7924_0": "#Замок#Вход",
 "scr_text_slash_scr_text_gml_7925_0": "#Магазин на скале",
 "scr_text_slash_scr_text_gml_7926_0": "Конец сада",
 "scr_text_slash_scr_text_gml_7927_0": "Верх замка",
 "scr_text_slash_scr_text_gml_7930_0": "* (Это дверь.^1)&* (Куда ты пойдёшь?)//",
 "scr_text_slash_scr_text_gml_7936_0_b": "* (Но ничего не произошло.)/%",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_629_0_b": "ДерКлинок2",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_630_0_b": "Меч, который произвольно сильнее#потому что подходит под сеттинг Главы 5.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_631_0_b": "Нет, ты ботан.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_632_0_b": "Крутые позы, Крис!",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_633_0_b": "Давай, Крис! «Рассекающий полумесяц тысячи лун»! Фаха!",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_652_0_b": "ТернТопор",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_653_0_b": "Топор из терновника. Ходят слухи, что его#порочность заражает всё, к чему он прикасается.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_654_0_b": "Буквально порочный.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_655_0_b": "Ура, я заражена!",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_656_0_b": "Ну... у роз тоже есть шипы.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_675_0_b": "СинТуфли",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_676_0_b": "Туфли именитой танцовщицы.#УМИРОТВОРИТЬ Ральзея стоит 0% ТП.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_677_0_b": "Ну уж нет, я их убью.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_678_0_b": "Помогает мне шагать в атаку!",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_679_0_b": "(Ты же ЗНАЕШЬ, я не могу носить обычную обувь...)",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_698_0_b": "АкваНож",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_699_0_b": "Озорной клинок. Атаки этим#оружием легче становятся критическими.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_700_0_b": "Слишком маленький. Крис-размер.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_701_0_b": "Эм, я могу пораниться...",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_702_0_b": "Это, эм, ностальгично.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_721_0_b": "ФлауэриШарф",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_722_0_b": "Шарф с надписью «Я <3 Флауэри».#Идеально подходит по размеру Ральзею.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_723_0_b": "Не-а, это для Ральзея.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_724_0_b": "Я, эм... он, он не налезает!",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_725_0_b": "Кто вообще такой Флауэри?",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_744_0": "РваныйШарф",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_745_0": "Шарф, разорванный в клочья в#бою — выяснилось, что он был чисто для вида.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_746_0": "...",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_747_0": "... я его надену.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_748_0": "Кто вообще ТАКОЙ Флауэри?",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_767_0": "ЗолРоза",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_768_0": "Кольца брони с розовым узором. Все шипы#направлены наружу, чтобы ты не поранился.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_769_0": "Чёрт, если бы только налезло!",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_770_0": "Ноэлль... могла бы это надеть.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_771_0": "Ого! Что-то, что я реально хочу носить?",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_790_0": "ОмелаБич",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_791_0": "Кнут из паразитического плюща с силой природы.#Только эксперты могут носить его как шарф.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_792_0": "Хватит прибивать это к вещам.",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_793_0": "Смотри, я венок?",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_794_0": "... а?",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_831_0": "Праздничный",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_877_0": "???",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_900_0": "$ +5%",
 "scr_weaponinfo_slash_scr_weaponinfo_gml_923_0": "Вампир",
 "UNUSED_slash_UNUSED_gml_2_0_b": "Хотя есть у меня кое-что.",
 "UNUSED_slash_UNUSED_gml_3_0_b": "И это воспоминания.",
 "UNUSED_slash_UNUSED_gml_4_0_b": "Воспоминания о моей жизни...",
 "UNUSED_slash_UNUSED_gml_5_0_b": "Может, это всё, чем я являюсь сейчас.",
 "UNUSED_slash_UNUSED_gml_6_0_b": "Собрание памяти...",
 "UNUSED_slash_UNUSED_gml_7_0_b": "...",
 "UNUSED_slash_UNUSED_gml_9_0": "«Не забывай».",
 "UNUSED_slash_UNUSED_gml_10_0": "Мне просто нужно продолжать твердить это себе...",
 "obj_ch5_DW22_slash_Step_0_gml_522_0": "ja",
