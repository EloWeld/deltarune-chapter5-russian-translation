{
 "obj_dw_pink_encounter_slash_Step_0_gml_643_0": "* Мне НРАВИТСЯ быть здесь!^1! Мне НРАВИТСЯ этот мир!^1! Мне НРАВИТСЯ это тело!!!/",
 "obj_dw_pink_encounter_slash_Step_0_gml_646_0": "\\EQ* П..^1. простите^1, Мисс Розовая^1, но этот Тёмный мир.../",
 "obj_dw_pink_encounter_slash_Step_0_gml_652_0": "\\ES* Он вроде как..^1. временный./",
 "obj_dw_pink_encounter_slash_Step_0_gml_658_0": "\\E2* Понимаю./",
 "obj_dw_pink_encounter_slash_Step_0_gml_660_0": "\\E7* ВЫ!!^1! ВЫ, котята, собираетесь его отобрать^1, да!?/",
 "obj_dw_pink_encounter_slash_Step_0_gml_665_0": "* ХА!!^1! Не смеши меня!!^1!/",
 "obj_dw_pink_encounter_slash_Step_0_gml_667_0": "* ПИНК вас первой НАКАЖЕТ!!/",
 "obj_dw_pink_encounter_slash_Step_0_gml_669_0": "* ВЫ БУДЕТЕ ИЗВИВАТЬСЯ В ЗЕМЛЕ, вымаливая прощение!!!/",
 "obj_dw_pink_encounter_slash_Step_0_gml_672_0": "\\E3* Это лучший способ извиниться^1, мяу~/%",
 "obj_dw_pink_encounter_slash_Step_0_gml_750_0": "\\E9* В-ваааа!^1! В-вы, ребята, и правда хулиганы^1, да...!!/",
 "obj_dw_pink_encounter_slash_Step_0_gml_751_0": "* Я просто..^1. хочу..^1. быть.../%",
 "obj_dw_pink_encounter_slash_Step_0_gml_757_0": "\\EA* ..^1. вот такой./%",
 "obj_dw_pink_encounter_slash_Step_0_gml_767_0": "\\EA* С тех пор, как я увидела куклу Азгора^1, я знала, что это Я.../",
 "obj_dw_pink_encounter_slash_Step_0_gml_768_0": "* С тех пор я как призрак вселилась в это тело^1, но.../",
 "obj_dw_pink_encounter_slash_Step_0_gml_769_0": "* Как только я попала в этот странный мир.../",
 "obj_dw_pink_encounter_slash_Step_0_gml_770_0": "* Я могла..^1. ДВИГАТЬСЯ в нём^1! Я могла ГОВОРИТЬ.../",
 "obj_dw_pink_encounter_slash_Step_0_gml_772_0": "\\E3* Я могла стать ОЖИВШЕЙ КОШКОдевочкой!!!/",
 "obj_dw_pink_encounter_slash_Step_0_gml_776_0": "\\EB* Почему вы, сопляки, должны это отобрать!?/",
 "obj_dw_pink_encounter_slash_Step_0_gml_780_0": "\\EQ* ..^1. нам жаль^1, но.../",
 "obj_dw_pink_encounter_slash_Step_0_gml_783_0": "\\E8* Этот мир..^1. оставлять его опасно.../%",
 "obj_dw_pink_encounter_slash_Step_0_gml_794_0": "\\ED* Но^1, эм^1, слушай^1. Мы не хотим портить тебе жизнь или типа того./",
 "obj_dw_pink_encounter_slash_Step_0_gml_795_0": "\\E7* Может, переберёшься к нам?/",
 "obj_dw_pink_encounter_slash_Step_0_gml_801_0": "*\\EA ..^1. к вам?/",
 "obj_dw_pink_encounter_slash_Step_0_gml_803_0": "\\ED* У нас..^1. тоже есть такой мир^1, знаешь./",
 "obj_dw_pink_encounter_slash_Step_0_gml_806_0": "\\E2* Там ты^1, наверное, тоже сможешь остаться кошкодевочкой./",
 "obj_dw_pink_encounter_slash_Step_0_gml_811_0": "\\EC* П..^1. правда!?/%",
 "obj_dw_pink_encounter_slash_Step_0_gml_825_0": "\\EE* Оооо^1, спасибо тебе^1! Спасибо^1! СПАСИБО!!!/",
 "obj_dw_pink_encounter_slash_Step_0_gml_826_0": "* Не могу поверить^1, мяу!^1! Мои надежды и мечты сияют!!/",
 "obj_dw_pink_encounter_slash_Step_0_gml_827_0": "* Я..^1. пойду собирать свои большие розовые сумки!!/%",
 "obj_dw_pink_encounter_slash_Step_0_gml_849_0": "ja",
 "obj_dw_pink_encounter_slash_Step_0_gml_851_0": "\\EF* А..^1. я.../%",
 "obj_dw_pink_encounter_slash_Step_0_gml_887_0": "\\E9* Нет!!^1! Я НЕ ХОЧУ уходить!^1! Ори^1! Все!^1! Я люблю их!!/",
 "obj_dw_pink_encounter_slash_Step_0_gml_889_0": "\\EJ* Эм^1, тебе не обязательно уходить прямо сейчас./",
 "obj_dw_pink_encounter_slash_Step_0_gml_890_0": "\\E0* Мы ещё не добрались до Фонтана./%",
 "obj_dw_pink_encounter_slash_Step_0_gml_907_0": "\\E4* А^1, ладно./%",
 "obj_dw_pink_encounter_slash_Step_0_gml_924_0": "\\E1* Ори^1, я останусь с тобой до конца^1, хорошо?/",
 "obj_dw_pink_encounter_slash_Step_0_gml_926_0": "ja",
 "obj_dw_pink_encounter_slash_Step_0_gml_963_0": "\\E5* ..^1. ну и ЧЕГО вы трое ждёте!?/%",
 "obj_dw_pink_encounter_slash_Step_0_gml_975_0": "\\E7* Валите уже отсюда К ЧЁРТУ!!!/%",
 "obj_dw_post_fountain_close_slash_Step_0_gml_92_0": "\\EZ* Э..^1. эй.../",
 "obj_dw_post_fountain_close_slash_Step_0_gml_95_0": "\\Eh* Почему мы всё ещё здесь...?/",
 "obj_dw_post_fountain_close_slash_Step_0_gml_98_0": "\\Eg* Н..^1. нет.../",
 "obj_dw_post_fountain_close_slash_Step_0_gml_103_0": "\\EF* Кто-то..^1. только что создал второй Фонтан!?/%",
 "obj_dw_post_fountain_close_slash_Step_0_gml_149_0": "\\Ed* Э..^1. ЭЙ!!!/",
 "obj_dw_post_fountain_close_slash_Step_0_gml_151_0": "\\EE* Олиствь это мне!!/%",
 "obj_dw_post_fountain_close_slash_Step_0_gml_231_0": "\\EG* Хех^1, думаешь, сможешь обогнать цветок!?/%",
 "obj_dw_post_fountain_close_slash_Step_0_gml_384_0": "\\EE* Что^1, уже отлиствляешься?/%",
 "obj_dw_post_fountain_close_slash_Step_0_gml_423_0": "\\EH* Не только ты можешь начать бой!/%",
 "obj_dw_post_fountain_close_slash_Step_0_gml_502_0": "* Появились враги!/%",
 "obj_dw_post_fountain_close_slash_Step_0_gml_513_0": "Попробуй теперь&убежать!/%",
 "obj_dw_post_fountain_close_slash_Step_0_gml_532_0": "* Флауэри пощадил Флорадинн!/%",
 "obj_dw_post_fountain_close_slash_Step_0_gml_543_0": "Похоже, теперь&только ты и я.../",
 "obj_dw_post_fountain_close_slash_Step_0_gml_544_0": "Получай!/%",
 "obj_dw_post_fountain_close_slash_Step_0_gml_704_0": "Ху!/%",
 "obj_dw_post_fountain_close_slash_Step_0_gml_715_0": "Ха!/%",
 "obj_dw_post_fountain_close_slash_Step_0_gml_744_0": "Хех^1,&как тебе&моя жарона!?/%",
 "obj_dw_post_fountain_close_slash_Step_0_gml_803_0": "Т..^1. ты можешь игнорировать&мои поддельные статы!?/",
 "obj_dw_post_fountain_close_slash_Step_0_gml_804_0": "Хех.../",
 "obj_dw_post_fountain_close_slash_Step_0_gml_805_0": "Кому вообще нужны статы^1,&а!?/",
 "obj_dw_post_fountain_close_slash_Step_0_gml_806_0": "У меня ещё&целый букет приёмов&в запасе!/%",
 "obj_dw_post_fountain_close_slash_Step_0_gml_898_0": "Похоже, ты&всё ещё..^1. &не понимаешь!/%",
 "obj_dw_post_fountain_close_slash_Step_0_gml_932_0": "Нет ничего сильнее&чем.../%",
 "obj_dw_post_fountain_close_slash_Step_0_gml_939_0": "м..^1. мечта..^1. Цветка...!/%",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_9_0": "#Слушать дальше",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_10_0": "#Не слушать дальше",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_15_0": "\\E2* Сьюзи^1! Иди наслаждайся своим сладким Фестивалем снежных конусов!/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_16_0": "\\E1* У нас свой Фестиваль проходит прямо в наших комнатах!/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_17_0": "\\E2* \"Лансерлимпийские игры!\"/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_24_0": "\\E3* Смотри^1, Сьюзи^1! Я наша национальная гордость и позор!/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_38_0": "\\E2* Круто^1, во что вы играете?/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_40_0": "\\E3* Баскетбол^1! (Я мяч)/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_41_0": "\\E3* Метание диска^1! (Я диск)/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_42_0": "\\E3* Конкурс злодейского смеха^1! (Я мяч)/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_43_0": "\\E3* Плохо принятая игра с талисманом^1! (Я талисман)/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_44_0": "\\E1* И^1, Лансербол!/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_46_0": "\\E6* ..^1. а ты мяч?/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_48_0": "\\E6* Не-а^1! Слишком опасно^1. Это Малый Папа./%",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_67_0": "\\E3* Ещё я призовая медаль./",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_70_0": "Класс!",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_75_0": "\\EA* Круто^1, потом повешу тебя на шею.\\f0/%",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_109_0": "* (Она выглядит занятой игрой.)/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_118_0": "\\EK* Я Занята/%",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_174_0": "\\ED* Крис Дорогой Милый Не Сейчас Мамочка Закидывает Мяч/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_175_0": "\\E9* Точка Ком (Точка Нет)/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_177_0": "\\EK* Пожалуйста, не называй себя мамочкой./",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_179_0": "\\EE*/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_185_0": "\\EH*/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_193_0": "\\ER* Почему Нет/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_195_0": "\\EH* Я Могу Родить/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_196_0": "\\ED* Безумные Слэм-данки/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_198_0": "\\EK* Мне кажется..^1. можно быть матерью..^1. без^1, родов?/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_200_0": "\\E0* Докажи/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_202_0": "\\EL* Ч-что?/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_204_0": "\\E1* Прямо Сейчас На Площадке/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_207_0": "\\EU* Н..^1. нет?/%",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_240_0": "\\E5* Ха-ха!!/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_241_0": "\\E3* Уже не такая \"Мамочка\", когда ты в \"Высшей Лиге\"^1, а!?/%",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_256_0": "\\EL* .../",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_258_0": "\\ED* Я Не Знаю Кто Он Но Он Прав/%",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_283_0": "\\E0* .../",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_284_0": "\\E1* Чувак^1, думаю, нам стоит типа^1, пойти навестить Ноэлль./%",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_363_0": "* Ого^1, МАЙК!^1! МАЙК!^1! Смотри, кто на Фанботроне!!/%",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_402_0": "* Ах^1, это камера \"Друзья-Толкатели\"!^1! Толкни разок для камеры!^1! Хаха!/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_403_0": "* И ЭЙ^1, погодите^1, а это кто!!!/%",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_428_0": "* Это камера \"Парню правда пора найти новый дом\"!!/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_437_0": "* Хаха^1! Он выглядит таким одиноким^1! Хаха!/%",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_454_0": "* Майк^1, выключи это^1. Выключи это./%",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_499_0": "* ЧТО!^1? МАЙК!^1? Ты..^1. собираешься показать НАС на Фанботроне!?/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_509_0": "* Н-но что подумают ЗРИТЕЛИ!^1? Ох^1, Майк-кун.../%",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_556_0": "* Тенна говорит, у него для нас новый КОЛЛАБ...!/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_557_0": "* Нам просто нужно залезть в эту штуку из папье-маше^1, и...?/%",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_562_0": "* Что бы это ни было^1, уверена, это безопасно./%",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_596_0": "* Налетай на прохладительное^1! Это наш новый^1, ОРИГИНАЛЬНЫЙ газированный напиток^1! \"ПИПСИ!\"/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_597_0": "* С классическим МЯГКИМ вкусом -/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_598_0": "* (Кхм^1, кхм) Эй^1, да что за фигня в этой штуке!?/%",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_603_0": "* Тут всего лишь немного яда^1. Всё нормально^1. Это в пределах государственных норм./%",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_648_0": "\\E3* О Кольцо И Палка Теперь Ты Мой Единственный Союзник/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_649_0": "\\EF* И Ещё Мой Бывший Муж Или Кем Он Там Является/",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_650_0": "\\EB* И Мой Сын Или Кем Он Там Является/%",
 "obj_dw_ralsei_castle_basketball_slash_Other_11_gml_655_0": "\\EA* Всё, Что Я Могу — Это Выложиться В Игре Полностью/"
}