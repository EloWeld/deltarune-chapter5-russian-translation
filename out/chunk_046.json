{
 "scr_text_slash_scr_text_gml_5812_0": "#Правая",
 "scr_text_slash_scr_text_gml_5813_0": "Верхняя",
 "scr_text_slash_scr_text_gml_5814_0": "Нижняя",
 "scr_text_slash_scr_text_gml_5819_0": "* Как изысканно./",
 "scr_text_slash_scr_text_gml_5820_0": "* Итак^1, первый вопрос./",
 "scr_text_slash_scr_text_gml_5821_0": "* Название какой картины первое по алфавиту?/",
 "scr_text_slash_scr_text_gml_5822_0": "\\C4 ",
 "scr_text_slash_scr_text_gml_5826_0": "* Как непослушно./",
 "scr_text_slash_scr_text_gml_5827_0": "* Кого-то надо бы хлыстом привести в порядок!/%",
 "scr_text_slash_scr_text_gml_5836_0": "#Левая",
 "scr_text_slash_scr_text_gml_5837_0": "#Правая",
 "scr_text_slash_scr_text_gml_5838_0": "Верхняя",
 "scr_text_slash_scr_text_gml_5839_0": "Нижняя",
 "scr_text_slash_scr_text_gml_5844_0": "* Как изысканно./",
 "scr_text_slash_scr_text_gml_5845_0": "* Итак^1, следующий вопрос./",
 "scr_text_slash_scr_text_gml_5846_0": "* Название какой картины третье по алфавиту?/",
 "scr_text_slash_scr_text_gml_5847_0": "\\C4 ",
 "scr_text_slash_scr_text_gml_5853_0": "* Неверно. Похоже, тебе не хватает организованности./",
 "scr_text_slash_scr_text_gml_5854_0": "* Кого-то надо бы хлыстом привести в порядок!/%",
 "scr_text_slash_scr_text_gml_5863_0": "#Левая",
 "scr_text_slash_scr_text_gml_5864_0": "#Правая",
 "scr_text_slash_scr_text_gml_5865_0": "Верхняя",
 "scr_text_slash_scr_text_gml_5866_0": "Нижняя",
 "scr_text_slash_scr_text_gml_5871_0": "* Как изысканно./",
 "scr_text_slash_scr_text_gml_5872_0": "* Итак^1, следующий вопрос./",
 "scr_text_slash_scr_text_gml_5873_0": "* Какая картина четвёртая?/",
 "scr_text_slash_scr_text_gml_5874_0": "\\C4 ",
 "scr_text_slash_scr_text_gml_5880_0": "* Неверно. Похоже, тебе не хватает организованности./",
 "scr_text_slash_scr_text_gml_5881_0": "* Кого-то надо бы хлыстом привести в порядок!/%",
 "scr_text_slash_scr_text_gml_5892_0": "* Всё верно!/",
 "scr_text_slash_scr_text_gml_5893_0": "* Я так рада, что могла бы кого-нибудь отхлестать!/%",
 "scr_text_slash_scr_text_gml_5899_0": "* Хм? Это номер 2^1, а не номер 4.../",
 "scr_text_slash_scr_text_gml_5900_0": "* Растерял всю организованность? Кого-то надо бы хлыстом привести в порядок!/%",
 "scr_text_slash_scr_text_gml_5906_0": "* Неверно. Похоже, тебе не хватает организованности./",
 "scr_text_slash_scr_text_gml_5907_0": "* Кого-то надо бы хлыстом привести в порядок!/%",
 "scr_text_slash_scr_text_gml_5915_0": "#Купить",
 "scr_text_slash_scr_text_gml_5916_0": "#Не покупать",
 "scr_text_slash_scr_text_gml_5917_0": " ",
 "scr_text_slash_scr_text_gml_5918_0": " ",
 "scr_text_slash_scr_text_gml_5935_0": "\\m3\t\t*Йо^1, (хихик)^1, нелегко быть&\tприспешником Королевы^1,&\tа?/",
 "scr_text_slash_scr_text_gml_5936_0": "\\m3\t\t*Может, сделаешь перерыв и&\tперекусишь?/",
 "scr_text_slash_scr_text_gml_5937_0": "\\m3\t\t*Ультра-зернистые CD-Бублики^1, всего&\tпо $400!/",
 "scr_text_slash_scr_text_gml_5938_0": "\\C2 ",
 "scr_text_slash_scr_text_gml_5942_0": "\\m3\t\t*Хочешь CD-бублик!? Всего&\t$400 за штуку!/",
 "scr_text_slash_scr_text_gml_5943_0": "\\C2 ",
 "scr_text_slash_scr_text_gml_5959_0": "\\m3\t\t*Приятно иметь с тобой&\tдело^1! ..^1. (хихик)/",
 "scr_text_slash_scr_text_gml_5965_0": "\\m3\t\t*Эй^1, у тебя нет места./",
 "scr_text_slash_scr_text_gml_5966_0": "\\m3\t\t*Что^1, набрал слишком много взяток?/%",
 "scr_text_slash_scr_text_gml_5972_0": "\\m3\t\t*Что!? Слишком дорого!?/",
 "scr_text_slash_scr_text_gml_5973_0": "\\m3\t\t*Ну и ладно^1! Лучшей сделки ты&\tнигде больше не&\tнайдёшь!/%",
 "scr_text_slash_scr_text_gml_5980_0": "\\m3\t\t*А? Да ладно^1, нельзя же жить&\tодним воздухом, которым она дышит!/",
 "scr_text_slash_scr_text_gml_5981_0": "\\m3\t\t*Поверь^1, я пробовал^1!&\t..^1. что?/%",
 "scr_text_slash_scr_text_gml_5986_0": "#Купить 400 бубликов",
 "scr_text_slash_scr_text_gml_5987_0": "#Купить 1 бублик",
 "scr_text_slash_scr_text_gml_5988_0": "Не покупать",
 "scr_text_slash_scr_text_gml_5989_0": " ",
 "scr_text_slash_scr_text_gml_6006_0": "\\m2\t\t*Хочешь купить бублик? Всего $80.&\\m3\tK_K^1, нет^1! Он стоит 400^1! 400!/",
 "scr_text_slash_scr_text_gml_6007_0": "\\m2\t\t*Понял./",
 "scr_text_slash_scr_text_gml_6008_0": "\\m2\t\t*Хочешь купить 400 бубликов?&\tВсего $80./",
 "scr_text_slash_scr_text_gml_6009_0": "\\C3 ",
 "scr_text_slash_scr_text_gml_6013_0": "\\m2\t\t*Один бублик^1, $80. 400 бубликов^1,&\t$80./",
 "scr_text_slash_scr_text_gml_6014_0": "\\C3 ",
 "scr_text_slash_scr_text_gml_6026_0": "%%",
 "scr_text_slash_scr_text_gml_6043_0": "* (Ты заплатил $80 за бублик.)/",
 "scr_text_slash_scr_text_gml_6044_0": "\\m2\t\t*Можно и мне один^1?&\\m3\tТы же их продаёшь!/%",
 "scr_text_slash_scr_text_gml_6049_0": "\\m2\t\t*Не хватает денег? Не&\tпереживай^1, этот за мой счёт!/",
 "scr_text_slash_scr_text_gml_6051_0": "* (Ты получил бублик.)/%",
 "scr_text_slash_scr_text_gml_6056_0": "\\m3\t\t*Нет места для бублика!&\\m2\tА как же дырка?/%",
 "scr_text_slash_scr_text_gml_6063_0": "\\m2\t\t*Ничего страшного. Я тоже&\tни одного не купил./%",
 "scr_text_slash_scr_text_gml_6068_0": "#Заглянуть#в конец",
 "scr_text_slash_scr_text_gml_6069_0": "#Заглянуть внутрь",
 "scr_text_slash_scr_text_gml_6070_0": " ",
 "scr_text_slash_scr_text_gml_6071_0": " ",
 "scr_text_slash_scr_text_gml_6074_0": "* Как ухаживать за человеком/",
 "scr_text_slash_scr_text_gml_6075_0": "* (Это книга для монстров о том, как ухаживать за людьми.)/",
 "scr_text_slash_scr_text_gml_6076_0": "\\C2 ",
 "scr_text_slash_scr_text_gml_6083_0": "* (Судя по карточке в конце...)/",
 "scr_text_slash_scr_text_gml_6084_0": "* (..^1. похоже, твоя мама брала её много раз много лет назад.)/%",
 "scr_text_slash_scr_text_gml_6090_0": "* (Внутри фотографии незнакомых людей.)/",
 "scr_text_slash_scr_text_gml_6091_0": "* (Ты быстро захлопнул книгу.)/%",
 "scr_text_slash_scr_text_gml_6097_0": "#Читать",
 "scr_text_slash_scr_text_gml_6098_0": "#Не читать",
 "scr_text_slash_scr_text_gml_6099_0": " ",
 "scr_text_slash_scr_text_gml_6100_0": " ",
 "scr_text_slash_scr_text_gml_6103_0": "* (Это Книга 1 о ДУШАХ. Прочитать?)/",
 "scr_text_slash_scr_text_gml_6104_0": "\\C2 ",
 "scr_text_slash_scr_text_gml_6111_0": "* ДУШУ издавна называли по-разному./",
 "scr_text_slash_scr_text_gml_6112_0": "* Родник нашего сострадания. Источник нашей воли./",
 "scr_text_slash_scr_text_gml_6113_0": "* Вместилище нашей \"жизненной силы.\"/",
 "scr_text_slash_scr_text_gml_6114_0": "* Но даже сейчас^1, истинное её назначение неизвестно./%",
 "scr_text_slash_scr_text_gml_6119_0": "%%",
 "scr_text_slash_scr_text_gml_6124_0": "#Профессия",
 "scr_text_slash_scr_text_gml_6125_0": "#Про брата",
 "scr_text_slash_scr_text_gml_6126_0": "Купить что-нибудь",
 "scr_text_slash_scr_text_gml_6127_0": "Ничего",
 "scr_text_slash_scr_text_gml_6130_0": "* эй^1, как дела?/",
 "scr_text_slash_scr_text_gml_6131_0": "\\C4 ",
 "scr_text_slash_scr_text_gml_6138_0": "\\E0* Эй^1, ты тут главный?/",
 "scr_text_slash_scr_text_gml_6140_0": "* я? я просто уборщик./",
 "scr_text_slash_scr_text_gml_6142_0": "\\EK* Тогда где кассир?/",
 "scr_text_slash_scr_text_gml_6144_0": "\\E2* кассир? у нас его нет./",
 "scr_text_slash_scr_text_gml_6146_0": "\\E5* Тогда у кого нам покупать!?/",
 "scr_text_slash_scr_text_gml_6148_0": "* у меня./",
 "scr_text_slash_scr_text_gml_6150_0": "\\EH* Значит, ты и есть кассир./",
 "scr_text_slash_scr_text_gml_6152_0": "\\E5* неа: я уборщик./",
 "scr_text_slash_scr_text_gml_6153_0": "\\E2* я просто подменяю./",
 "scr_text_slash_scr_text_gml_6155_0": "\\E5* А другие сотрудники есть?/",
 "scr_text_slash_scr_text_gml_6157_0": "* неа./",
 "scr_text_slash_scr_text_gml_6159_0": "\\EH* Так найми кого-нибудь ещё!?/",
 "scr_text_slash_scr_text_gml_6161_0": "\\E5* воу^1, думаешь, я потяну такое на зарплату уборщика?/%",
 "scr_text_slash_scr_text_gml_6170_0": "\\E2* кстати. насчёт моего брата.../",
 "scr_text_slash_scr_text_gml_6171_0": "\\E1* похоже, сегодня вы с ним не встретитесь./",
 "scr_text_slash_scr_text_gml_6172_0": "\\E2* да^1, обидно, когда не срастается./",
 "scr_text_slash_scr_text_gml_6173_0": "\\E0* извиняюсь./",
 "scr_text_slash_scr_text_gml_6174_0": "\\E2* уверен, когда-нибудь вы увидитесь./",
 "scr_text_slash_scr_text_gml_6175_0": "\\E5* может, примерно когда твой брат вернётся домой?/%",
 "scr_text_slash_scr_text_gml_6187_0": "* брат...?/",
 "scr_text_slash_scr_text_gml_6188_0": "\\E2* о чём ты говоришь?/",
 "scr_text_slash_scr_text_gml_6189_0": "\\E1* .../",
 "scr_text_slash_scr_text_gml_6190_0": "\\E1* ..^1. у меня нет брата./"
}
