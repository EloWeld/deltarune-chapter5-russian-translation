 "obj_dw_fcastle_orange_puppet_introduction_slash_Step_0_gml_537_0": "ja",
 "obj_dw_fcastle_pinkroom_slash_Other_17_gml_52_0": "* АГА^1! Я поняла — будучи пещерным отшельником, ты ведь почти не встречаешь людей./",
 "obj_dw_fcastle_pinkroom_slash_Other_17_gml_53_0": "* Раз уж ты встретил меня^1, я тоже буду появляться здесь!/",
 "obj_dw_fcastle_pinkroom_slash_Other_17_gml_58_0": "* Чувствуешь мою технику?/",
 "obj_dw_fcastle_pinkroom_slash_Other_17_gml_61_0": "Найти#Розовые монеты#(50 F$)",
 "obj_dw_fcastle_pinkroom_slash_Other_17_gml_62_0": "Не надо",
 "obj_dw_fcastle_pinkroom_slash_Other_17_gml_79_0": "* Что!^1? РОЗОВЫХ МОНЕТ больше не осталось...!/",
 "obj_dw_fcastle_pinkroom_slash_Other_17_gml_80_0": "* Это ОТЛИЧНО^1. Кажется, у меня на них была АЛЛЕРГИЯ../%",
 "obj_dw_fcastle_pinkroom_slash_Other_17_gml_94_0": "* У тебя не хватает ФЛАУЭРИ-ДОЛЛАРОВ!?/",
 "obj_dw_fcastle_pinkroom_slash_Other_17_gml_95_0": "* Попробуй найти ХЛЕБНОГО ШЕФА^1, у него много видов ТЕСТА./%",
 "obj_dw_fcastle_pinkroom_slash_Other_17_gml_113_0": "* Ха^1! Найти РОЗОВЫЙ МЕТАЛЛ..^1. вот это^1, я умею!/",
 "obj_dw_fcastle_pinkroom_slash_Other_17_gml_114_0": "* Апчхи!!!../%",
 "obj_dw_fcastle_pinkroom_slash_Other_17_gml_215_0": "* ~1 в САДУ.",
 "obj_dw_fcastle_pinkroom_slash_Other_17_gml_216_0": "* ~1 на ОБРЫВЕ.",
 "obj_dw_fcastle_pinkroom_slash_Other_17_gml_217_0": "* ~1 в ВОСТОЧНОЙ ЧАСТИ ЗАМКА.",
 "obj_dw_fcastle_pinkroom_slash_Other_17_gml_218_0": "* ~1 в ЗАПАДНОЙ ЧАСТИ ЗАМКА.",
 "obj_dw_fcastle_pinkroom_slash_Other_17_gml_219_0": "* ~1 НА ВЕРШИНЕ ЗАМКА.",
 "obj_dw_fcastle_pinkroom_slash_Step_0_gml_85_0": "\\EJ* Здравствуйте...^1? Есть тут кто?/%",
 "obj_dw_fcastle_pinkroom_slash_Step_0_gml_91_0": "\\E7* Готов спорить, там кто-то жутко сильный./%",
 "obj_dw_fcastle_pinkroom_slash_Step_0_gml_110_0": "\\EH* Оо^1, может, с уникальной и запоминающейся темой!/",
 "obj_dw_fcastle_pinkroom_slash_Step_0_gml_112_0": "\\E6* Тсс^1, я кого-то слышу!/%",
 "obj_dw_fcastle_pinkroom_slash_Step_0_gml_145_0": "ja",
 "obj_dw_fcastle_pinkroom_slash_Step_0_gml_164_0": "\\EX* Ой^1, эм^1, это просто Оранжевая.../%",
 "obj_dw_fcastle_pinkroom_slash_Step_0_gml_178_0": "ja",
 "obj_dw_fcastle_pinkroom_slash_Step_0_gml_187_0": "ja",
 "obj_dw_fcastle_pinkroom_slash_Step_0_gml_190_0": "\\EK* Крис^1, может, нам нужно использовать ключ где-то ещё...?/",
 "obj_dw_fcastle_pinkroom_slash_Step_0_gml_193_0": "\\EN* Псст^1, Ральзей^1, да ладно^1. Мы можем её вздуть, если она хочет./",
 "obj_dw_fcastle_pinkroom_slash_Step_0_gml_199_0": "ja",
 "obj_dw_fcastle_pinkroom_slash_Step_0_gml_209_0": "ja",
 "obj_dw_fcastle_pinkroom_slash_Step_0_gml_232_0": "ja",
 "obj_dw_fcastle_pinkroom_slash_Step_0_gml_247_0": "\\EK* .../",
 "obj_dw_fcastle_pinkroom_slash_Step_0_gml_249_0": "\\E0* ..^1. пойдём проверим её./%",
 "obj_dw_fcastle_pinkshop_slash_Other_11_gml_79_0": "ja",
 "obj_dw_fcastle_pinkshop_slash_Other_11_gml_80_0": "ja",
 "obj_dw_fcastle_pinkshop_slash_Other_11_gml_81_0": "ja",
 "obj_dw_fcastle_pinkshop_slash_Other_11_gml_82_0": "ja",
 "obj_dw_fcastle_pinkshop_slash_Other_11_gml_83_0": "ja",
 "obj_dw_fcastle_pinkshop_slash_Other_11_gml_84_0": "ja",
 "obj_dw_fcastle_pinkshop_slash_Other_11_gml_85_0": "ja",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_61_0": "* Купить это за ~1 Флауэри-долларов и ~2 Розовых монет?/",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_62_0": "Купить",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_63_0": "Не покупать",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_76_0": "ja",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_78_0": "* «АкваНож» - оружие для Криса^1. С ним легче наносить критический урон./",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_114_0": "ja",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_116_0": "* «ОчкиСета» - Броня^1. Дольше остаёшься неуязвимым после получения урона./",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_152_0": "ja",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_154_0": "* «СиниеТуфли» - оружие для Ральзея^1. Усмирение будет стоить 0 ТП./",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_190_0": "ja",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_192_0": "* «ЖёлтаяШляпа» - Броня^1. Заклинания на 20`% сильнее./",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_228_0": "ja",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_230_0": "* «О.Перчатка» - Броня^1. КОСШМАР Сьюзи будет стоить меньше ТП./",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_294_0": "* «ЗелёнФартук» - Броня^1. Немного восстанавливает HP при защите./",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_331_0": "* «ФлауэриШарф» - лучшее оружие Ральзея^1. Стоит всего 1F$./",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_333_0": "\\EO* Очевидно, тебе он нужен..^1. правда^1, Раль?/",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_335_0": "* Купить это за 1 Флауэри-доллар?/",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_381_0": "* (У тебя не хватает.)/%",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_439_0": "\\ER* Я..^1. я не буду носить эту дурацкую ленту!/%",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_571_0": "ja",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_572_0": "ja",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_573_0": "ja",
 "obj_dw_fcastle_pinkshop_slash_Step_0_gml_574_0": "ja",
 "obj_dw_fcastle_post_party_jail_slash_Create_0_gml_101_0": "* Ззз..^1. СПЛЮ..^1. СПЛ2.../%",
 "obj_dw_fcastle_post_party_jail_slash_Create_0_gml_115_0": "* Ззз..^1. Господин Ральзей..^1. такой..^1. умиротворяющий.../%",
 "obj_dw_fcastle_post_party_jail_slash_Create_0_gml_129_0": "* Ага^1, нас всех усыпили^1. Вот почему я не работаю./%",
 "obj_dw_fcastle_post_party_jail_slash_Step_0_gml_28_0": "\\EK* Слушай^1, разве тебе^1, эм^1, не нравилось^1? Быть дворецким и всё такое?/",
 "obj_dw_fcastle_post_party_jail_slash_Step_0_gml_30_0": "\\En* Как оказалось^1, тут всё зависит от контекста./%",
 "obj_dw_fcastle_post_party_jail_slash_Step_0_gml_42_0": "* (Рабочий сезон закончился.)/",
 "obj_dw_fcastle_post_party_jail_slash_Step_0_gml_43_0": "* (Начинается сезон миграции.)/%",
 "obj_dw_fcastle_post_party_jail_slash_Step_0_gml_107_0": "\\E7* Ральзей!/%",
 "obj_dw_fcastle_post_party_jail_slash_Step_0_gml_117_0": "\\EK* Тебя^1, эм^1, снова превратили в дворецкого./",
 "obj_dw_fcastle_post_party_jail_slash_Step_0_gml_119_0": "\\En* .../%",
 "obj_dw_fcastle_post_party_jail_slash_Step_0_gml_189_0": "\\EK* Ладно^1, ага^1. Не будем об этом говорить./%",
 "obj_dw_fcastle_post_party_jail_slash_Step_0_gml_231_0": "* (Лучше пусть Сет насладится призом.)/%",
 "obj_dw_fcastle_right_endingscene_slash_Create_0_gml_125_0": "* (Возишься со съедобной цветочной композицией...)/%",
 "obj_dw_fcastle_right_endingscene_slash_Create_0_gml_130_0": "ja",
 "obj_dw_fcastle_right_endingscene_slash_Create_0_gml_131_0": "ja",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_121_0": "\\E7* Зелёный^1, эй^1, Зелёный^1! Как дела?/%",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_133_0": "\\E6* ..^1. а^1? Ты хотел рассказать мне рецепт.../",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_134_0": "\\Ew* ..^1. для очень вкусного праздничного печенья...?/%",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_153_0": "\\EM* Эм^1, простите, ребят^1, я сейчас вернусь!/%",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_162_0": "\\EI* .../",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_164_0": "\\E0* Полагаю, нам стоит..^1. дать ей немного пространства./%",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_170_0": "Закрыть глаза#и подумать#о Сьюзи",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_171_0": "Ага",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_192_0": "\\ED* ..^1. а..^1. а^1? Эм^1, если хочешь^1! Просто.../",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_193_0": "\\E9* Я подумал^1, эм..^1. может, в этот раз.../",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_194_0": "\\E5* Ты мог бы..^1. дать ей немного личного пространства?/",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_202_0": "\\Ea* ..^1. это приятно^1, что у неё..^1. есть кто-то в реальном мире./",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_204_0": "\\ED* К-кроме тебя^1, конечно же^1, Крис!/",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_208_0": "\\EI* .../",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_210_0": "\\E1* Я.../",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_212_0": "\\E2* Может^1, пойду поищу цветы^1, тоже.../%",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_238_0": "Закрыть глаза#и подумать#о Ральзее",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_239_0": "Расслабиться",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_272_0": "* (Ты расслабился...)/%",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_277_0": "* (...)/%",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_282_0": "Закрыть глаза#и подумать#о Ральзее",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_283_0": "Даже не думай,#даже если кажется,#что это важно",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_328_0": "\\E7* Ладно^1, у меня есть^1, эм^1, совет!/%",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_342_0": "\\E6* ..^1. а где Ральзей?/%",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_350_0": "\\EF* Ой блин^1. Стой^1. Я только что вспомнил./",
 "obj_dw_fcastle_right_endingscene_slash_Step_0_gml_351_0": "\\EG* Мы шли по офигенно высокой траве./"
}