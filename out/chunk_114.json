{
 "obj_pink_enemy_slash_Step_0_gml_607_0": "* Розовая смотрит в зеркало..^1. она не оборачивается.",
 "obj_pink_enemy_slash_Step_0_gml_611_0": "* Розовая бормочет что-то себе под нос^1, и дым усиливается.",
 "obj_pink_enemy_slash_Step_0_gml_612_0": "* Розовая выкрикивает магические слова, зацензуренные сердечками.",
 "obj_pink_enemy_slash_Step_0_gml_613_0": "* Болванчики-пули Розовой пытаются её подбодрить.",
 "obj_pink_enemy_slash_Step_0_gml_617_0": "* ТЕЛО Розовой подмигивает!&* ПРИЗРАК Розовой показывает язык!",
 "obj_pink_enemy_slash_Step_0_gml_618_0": "* ТЕЛО Розовой протягивает руки!&* ПРИЗРАК Розовой отбивает руки своего ТЕЛА!",
 "obj_pink_enemy_slash_Step_0_gml_619_0": "* Болванчики-пули Розовой не знают, за кого болеть!",
 "obj_pink_enemy_slash_Step_0_gml_624_0": "* ТЕЛО Розовой вздрагивает!&* ПРИЗРАК Розовой выглядит обеспокоенным^1, затем отворачивается!",
 "obj_pink_enemy_slash_Step_0_gml_625_0": "* ТЕЛО Розовой испускает дым!&* ПРИЗРАК Розовой тянется к нему^1, затем останавливается!",
 "obj_pink_enemy_slash_Step_0_gml_626_0": "* Голос ТЕЛА Розовой срывается!&* ПРИЗРАК Розовой начинает что-то говорить^1, затем замолкает!",
 "obj_pink_enemy_slash_Step_0_gml_630_0": "* Воздух кружится в розовом хаосе.",
 "obj_pink_enemy_slash_Step_0_gml_631_0": "* Пахнет духами и пластиком.",
 "obj_pink_enemy_slash_Step_0_gml_633_0": "* Метр ДОКИ почти заполнен!",
 "obj_pink_enemy_slash_Step_0_gml_636_0": "* Розовая шатается от удара СВИДАНИЕМ.&* Метр ТП сброшен!",
 "obj_pink_enemy_slash_Step_0_gml_637_0": "* Розовая раскололась на ПРИЗРАКА и ТЕЛО!&* Метр ТП сброшен!",
 "obj_pink_enemy_slash_Step_0_gml_638_0": "* ТЕЛО Розовой сильно повреждено...!",
 "obj_pink_enemy_slash_Step_0_gml_665_0": "* ПИНК - Призрак Светлых в теле девочки-волшебницы^1. Заставь её сердце докнуть флиртом^1, и...!?/%",
 "obj_pink_enemy_slash_Step_0_gml_666_0": "* ПИНК - Призрак Светлых в теле Тёмной девочки^1. Заполни МЕТР ДОКИ, чтобы устроить СВИДАНИЕ!/%",
 "obj_pink_enemy_slash_Step_0_gml_667_0": "* ПИНК - Призрак Светлых^1, или тело Тёмной!^1? Заполни МЕТР ДОКИ, чтобы устроить СВИДАНИЕ с обеими!/%",
 "obj_pink_enemy_slash_Step_0_gml_668_0": "* ПИНК - Без духа, который бы им управлял^1, тело развалится..^1./%",
 "obj_pink_enemy_slash_Step_0_gml_674_0": "* Вы флиртовали!",
 "obj_pink_enemy_slash_Step_0_gml_718_0": "* Все флиртовали изо всех сил!/%",
 "obj_pink_enemy_slash_Step_0_gml_746_0": "* Все использовали ГИГА ФЛИРТ!/%",
 "obj_pink_enemy_slash_Step_0_gml_757_0": "* Сьюзи флиртовала!",
 "obj_pink_enemy_slash_Step_0_gml_778_0": "* Сьюзи флиртовала изо всех сил!",
 "obj_pink_enemy_slash_Step_0_gml_797_0": "* Сьюзи решила поделиться предметом с Розовой!/%",
 "obj_pink_enemy_slash_Step_0_gml_821_0": "* ~1&* Розовая это возненавидела! ДОКИ не увеличилось!/%",
 "obj_pink_enemy_slash_Step_0_gml_824_0": "* ~1&* Розовая это стерпела! +1 ДОКИ!/%",
 "obj_pink_enemy_slash_Step_0_gml_827_0": "* ~1&* Розовой это понравилось! +2 ДОКИ!/%",
 "obj_pink_enemy_slash_Step_0_gml_830_0": "* ~1&* Розовая это обожает! +3 ДОКИ!/%",
 "obj_pink_enemy_slash_Step_0_gml_833_0": "* ~1&* ! +4 ДОКИ!/%",
 "obj_pink_enemy_slash_Step_0_gml_836_0": "* ~1&* Розовая была в экстазе! +15 ДОКИ!/%",
 "obj_pink_enemy_slash_Step_0_gml_853_0": "* Ральзей флиртовал!",
 "obj_pink_enemy_slash_Step_0_gml_874_0": "* Ральзей флиртовал изо всех сил!",
 "obj_pink_enemy_slash_Step_0_gml_900_0": "* Собрано обожание^1! Макс. ТП увеличился!",
 "obj_pink_enemy_slash_Step_0_gml_933_0": "* Ральзей выглядел очаровательно!&* Появились СЕРДЕЧКИ!&* МАКС. ТП вырос!/%",
