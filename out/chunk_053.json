{
 "obj_dojo_spareenemy_slash_Step_0_gml_28_0": "Бои пойдут&намного быстрее!&Вот и всё!/%",
 "obj_dojo_spareenemy_slash_Step_0_gml_32_0": "Босс!/",
 "obj_dojo_spareenemy_slash_Step_0_gml_33_0": "Можно ДЕЙСТВОВАТЬ&и ЩАДИТЬ за&один ход!/",
 "obj_dojo_spareenemy_slash_Step_0_gml_34_0": "Если знаешь, что&ДЕЙСТВИЕ Криса даст&врагу 100`% пощады.../",
 "obj_dojo_spareenemy_slash_Step_0_gml_35_0": "ПОЩАДИ его тем&же ходом&Сьюзи&или Ральзеем!/%",
