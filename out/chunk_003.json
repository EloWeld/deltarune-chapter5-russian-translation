{
 "obj_clubsenemy_old_slash_Step_0_gml_98_0": "Ой, ой!&Хочу&милого мальчика.",
 "obj_clubsenemy_old_slash_Step_0_gml_99_0": "Кого-то&МИЛОГО, как&я!",
 "obj_clubsenemy_old_slash_Step_0_gml_100_0": "...&Ну&ладно.",
 "obj_clubsenemy_old_slash_Step_0_gml_105_0": "Я целюсь&с помощью&геймпада!",
 "obj_clubsenemy_old_slash_Step_0_gml_106_0": "ИДИОТ!&Мышь и&клавиатура!",
 "obj_clubsenemy_old_slash_Step_0_gml_107_0": "Хватит&уже, вы&двое...",
 "obj_clubsenemy_old_slash_Step_0_gml_117_0": "Обожаю&запах&деревьев.",
 "obj_clubsenemy_old_slash_Step_0_gml_118_0": "О!&Я тоже!",
 "obj_clubsenemy_old_slash_Step_0_gml_119_0": "От пыльцы&я...&Э, точно!",
 "obj_clubsenemy_old_slash_Step_0_gml_123_0": "Призрак&сказал, что я&тупая.",
 "obj_clubsenemy_old_slash_Step_0_gml_124_0": "Это была я,&идиотка!",
 "obj_clubsenemy_old_slash_Step_0_gml_125_0": "Хватит&уже, вы&двое...",
 "obj_clubsenemy_old_slash_Step_0_gml_130_0": "Наша любимая&видеоигра&это...",
 "obj_clubsenemy_old_slash_Step_0_gml_131_0": "Замолчи!!&Над нами&посмеются!!!",
 "obj_clubsenemy_old_slash_Step_0_gml_132_0": "Хватит&уже, вы&двое...",
 "obj_clubsenemy_old_slash_Step_0_gml_139_0": "Ой, он это&СДЕЛАЛ!?&Такой заботливый!",
 "obj_clubsenemy_old_slash_Step_0_gml_140_0": "Это ТААК&мило!&Хочу это!",
 "obj_clubsenemy_old_slash_Step_0_gml_141_0": "(Не слишком&ли это...&по-детски?)",
 "obj_clubsenemy_old_slash_Step_0_gml_146_0": "Ай!&Больно!",
 "obj_clubsenemy_old_slash_Step_0_gml_147_0": "Терпи,&идиотка!",
 "obj_clubsenemy_old_slash_Step_0_gml_148_0": "(Мы&снова&ссоримся!?)",
 "obj_clubsenemy_old_slash_Step_0_gml_204_0": "＊ Кловер сверкает тремя ужасными улыбками.",
 "obj_clubsenemy_old_slash_Step_0_gml_205_0": "＊ Кловер препирается сама с собой.",
 "obj_clubsenemy_old_slash_Step_0_gml_206_0": "＊ Кловер шепчется о милых мальчиках.",
