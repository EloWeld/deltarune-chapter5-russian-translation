{
 "obj_dw_fcastle_foxhunt_slash_Create_0_gml_163_0": "Я БЫЛ#СЕРЬЁЗЕН#!!!!!!!!#!!!!!!!!",
 "obj_dw_fcastle_foxhunt_slash_Create_0_gml_171_0": "\\EH* Отличная работа^1, Крис^1! Ты справился!/",
 "obj_dw_fcastle_foxhunt_slash_Create_0_gml_172_0": "\\EK* Тебе^1, эм^1, было весело?/",
 "obj_dw_fcastle_foxhunt_slash_Create_0_gml_182_0": "\\EJ* Эм^1, Крис^1? Просто предчувствие^1, но..^1. не думаю, что.../",
 "obj_dw_fcastle_foxhunt_slash_Create_0_gml_183_0": "\\EM* Спихивание статуй с уступа в этой комнате.../",
 "obj_dw_fcastle_foxhunt_slash_Create_0_gml_184_0": "\\EK* ..^1. даст что-то ещё./%",
 "obj_dw_fcastle_foxhunt_slash_Create_0_gml_191_0": "\\EK* (К-Крис вроде получает от этого удовольствие^1, так что...)/%",
 "obj_dw_fcastle_foxhunt_slash_Step_0_gml_163_0": "* Ты нашёл только 1 лису.&* Больше не можешь найти?&* Кии хи хи./%",
 "obj_dw_fcastle_foxhunt_slash_Step_0_gml_166_0": "* Ты нашёл только ~1 лис.&* Больше не можешь найти?&* Кии хи хи./%",
 "obj_dw_fcastle_foxhunt_slash_Step_0_gml_171_0": "* Кии хи хи^1, Сет сказал не пропускать тебя...&* Ни при каких обстоятельствах!/",
 "obj_dw_fcastle_foxhunt_slash_Step_0_gml_172_0": "* Разве что^1, ты найдёшь хотя бы \\cY3 лис\\cW.&* Так сказал Сет./%",
 "obj_dw_fcastle_foxhunt_slash_Step_0_gml_321_0": "* Кии хи хи.../",
 "obj_dw_fcastle_foxhunt_slash_Step_0_gml_322_0": "* Ты нашёл лис^1,&ты нашёл лис!/%",
 "obj_dw_fcastle_foxhunt_slash_Step_0_gml_407_0": "* Но^1, одну ты пропустил~/%",
 "obj_dw_fcastle_foxhunt_slash_Step_0_gml_808_0": "\\Ey* Ага.../",
 "obj_dw_fcastle_foxhunt_slash_Step_0_gml_810_0": "\\Ey* Д..^1. да.../%",
 "obj_dw_fcastle_foxhunt_slash_Step_0_gml_818_0": "\\EK* О-ой...^1! Прости, что заставил тебя чуть-чуть накричать на меня^1, Крис./",
 "obj_dw_fcastle_foxhunt_slash_Step_0_gml_819_0": "\\EK* Немного^1, эм..^1. покричать./",
 "obj_dw_fcastle_foxhunt_slash_Step_0_gml_820_0": "\\EL* И^1, эм^1, тебе не нужно постоянно повторять^1, эм.../",
 "obj_dw_fcastle_foxhunt_slash_Step_0_gml_821_0": "\\EK* «Восклицательный знак» снова и снова.../",
 "obj_dw_fcastle_foxhunt_slash_Step_0_gml_823_0": "\\Ey* Ага, приходится./%",
 "obj_dw_fcastle_foyer_slash_Create_0_gml_61_0": "\\En* Ну..^1. полагаю, ИМЕННО ЭТО перегораживает путь./",
 "obj_dw_fcastle_foyer_slash_Create_0_gml_62_0": "\\EQ* Может, если мы дотянемся до ножниц с обеих сторон^1, мы сможем...?/",
 "obj_dw_fcastle_foyer_slash_Create_0_gml_63_0": "\\EK* Эмм..^1. избавиться от этого?/%",
 "obj_dw_fcastle_foyer_slash_Create_0_gml_68_0": "\\E7* Чувак, нам бы такую же штуку про нас самих./%",
 "obj_dw_fcastle_foyer_slash_Create_0_gml_84_0": "* (Росток.)/%",
 "obj_dw_fcastle_foyer_slash_Create_0_gml_89_0": "* (Он неподвижен.)/%",
 "obj_dw_fcastle_foyer_slash_Create_0_gml_102_0": "* (Цветочное кафе.)/",
 "obj_dw_fcastle_foyer_slash_Create_0_gml_103_0": "* (Имей большое сердце — и оно откроется соразмерно.)/%",
 "obj_dw_fcastle_foyer_slash_Create_0_gml_106_0": "* (Цветы расцветают в твоём сердце.)/",
 "obj_dw_fcastle_foyer_slash_Create_0_gml_107_0": "* (Цветочное кафе^1, открыто настолько, насколько открыто твоё сердце.)/%",
 "obj_dw_fcastle_foyer_slash_Step_0_gml_210_0": "\\EE* Тёмный Фонтан, должно быть, наверху.../",
 "obj_dw_fcastle_foyer_slash_Step_0_gml_211_0": "\\E2* Крис^1, давай выясним, как туда добраться!/%",
 "obj_dw_fcastle_fusumadodge_slash_Step_0_gml_25_0": "Эта история...#думаешь,#ему понравится?",
 "obj_dw_fcastle_fusumadodge_slash_Step_0_gml_204_0": "Ууу, а сможешь#уклониться от этого?",
 "obj_dw_fcastle_fusumadodge_slash_Step_0_gml_448_0": "Вращение",
 "obj_dw_fcastle_fusumadodge_slash_Step_0_gml_449_0": "Дай покручу...",
 "obj_dw_fcastle_fusumadodge_slash_Step_0_gml_484_0": "Ууу, ему нравятся#быстро крутящиеся ножи!?#Ладно!",
 "obj_dw_fcastle_fusumadodge_slash_Step_0_gml_540_0": "Ууу, думаешь#Азгору понравятся#мои ножи!?",
 "obj_dw_fcastle_fusumadodge_slash_Step_0_gml_570_0": "Сет! Думаю,#Азгору понравится#быстро крутящаяся книга!!",
 "obj_dw_fcastle_fusumadodge_slash_Step_0_gml_588_0": "Можно... я попробую#сначала обычный!?",
 "obj_dw_fcastle_fusumadodge_slash_Step_0_gml_640_0": "О-они здесь!#Бирюзовая!#Останови их!!",
 "obj_dw_fcastle_fusumadodge_slash_Step_0_gml_664_0": "Т...#Ты даже не#воспользовался дверями...?",
 "obj_dw_fcastle_fusumadodge_slash_Step_0_gml_670_0": "Чёрт!!#Они воспользовались#дверями!!",
 "obj_dw_fcastle_fusumadodge_slash_Step_0_gml_676_0": "Хех,#как тебе#такое!?",
 "obj_dw_fcastle_gloves_tower_slash_Step_0_gml_80_0": "Народ, мои перчатки#это не ЛЕГКО!",
 "obj_dw_fcastle_gloves_tower_slash_Step_0_gml_90_0": "Ну ты не#должен их#ОТБИВАТЬ!",
 "obj_dw_fcastle_gloves_tower_slash_Step_0_gml_123_0": "Просто!#СТОЙ НЕПОДВИЖНО!",
 "obj_dw_fcastle_gloves_tower_slash_Step_0_gml_163_0": "Это читерство!!#Я всё расскажу!!",
 "obj_dw_fcastle_gloves_tower_slash_Step_0_gml_198_0": "ВИДИШЬ?#Это ДЕЙСТВИТЕЛЬНО тяжело,#да?",
 "obj_dw_fcastle_gloves_tower_slash_Step_0_gml_234_0": "Ха! СИНИЙ сказал мне,#что мои пули#хорошие!",
 "obj_dw_fcastle_gloves_tower_slash_Step_0_gml_265_0": "С... Синий говорит,#мои пули#хорошие...!",
 "obj_dw_fcastle_gloves_tower_slash_Step_0_gml_306_0": "ХВАТИТ ОТБИВАТЬ!!#Я РАССКАЖУ ФЛАУЭРИ,#ЧТО ТЫ ОТБИВАЕШЬ!!!",
 "obj_dw_fcastle_green_checkpoint_slash_Step_0_gml_115_0": "\\EZ* Зелёный.../",
 "obj_dw_fcastle_green_checkpoint_slash_Step_0_gml_119_0": "\\EC* Что..^1. ты собираешься с нами сделать!?/%",
 "obj_dw_fcastle_green_checkpoint_slash_Step_0_gml_148_0": "\\E3* ..^1. ты^1, эм^1, поднял цены на $1?/",
 "obj_dw_fcastle_green_checkpoint_slash_Step_0_gml_150_0": "\\EQ* Понятно^1, это идеальный магазин.../%",
