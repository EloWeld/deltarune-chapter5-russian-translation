 "obj_dw_fcastle_cafe_slash_Other_13_gml_1245_0": "ja",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1247_0": "ja",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1249_0": "ja",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1251_0": "Я — ДА!!!",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1257_0": "ja",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1327_0": "\\E9* Знаешь^1, Сет.../",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1328_0": "\\EE* Кое-что в Флауэри меня реально бесит.../",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1330_0": "ja",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1332_0": "\\EE* В-вот именно!^1! Он не использует правильные термины.../",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1334_0": "ja",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1336_0": "\\EE* Он строит из себя того, кто знает больше, чем знает на самом деле!!/",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1338_0": "ja",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1339_0": "ja",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1341_0": "\\Ep* ИМЕННО!!!/%",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1403_0": "\\EL* ..^1. п-погодите^1. Я^1, я не хочу быть лидером./",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1405_0": "ja",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1407_0": "Мне нравится жёлтая птица, которая\nпоявляется во время ДЕЙСТВИЯ Джевила...",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1412_0": "ja",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1474_0": "ja",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1476_0": "\\EK* Погоди^1, чего^1? Задрот^1, уважает МЕНЯ^1? Чего?/",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1478_0": "ja",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1526_0": "ja",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1544_0": "ja",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1546_0": "\\EH* Сет^1! Твой герой^1, Бёрдли^1, тоже её вполне себе любит...!/",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1548_0": "ja"
