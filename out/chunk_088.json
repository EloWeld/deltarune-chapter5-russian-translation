 "obj_dw_fcastle_cafe_slash_Other_13_gml_1146_0": "ЭТО НЕ КРАСИВО!!",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1152_0": "ja",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1239_0": "ja",
 "obj_dw_fcastle_cafe_slash_Other_13_gml_1241_0": "ja",
