 "scr_text_slash_scr_text_gml_4933_0_b": " ",
 "scr_text_slash_scr_text_gml_7046_0": "#Прости, я решу #головоломку",
 "scr_text_slash_scr_text_gml_7047_0": "#Продолжить",
 "scr_text_slash_scr_text_gml_7048_0_b": "",
 "scr_text_slash_scr_text_gml_7049_0": "",
 "scr_text_slash_scr_text_gml_7052_0_b": "\\E2* Крис? Ты..^1. ты правда меня бросишь...?/",
 "scr_text_slash_scr_text_gml_7053_0": "\\C2 ",
 "scr_text_slash_scr_text_gml_7062_0": "\\E3* С-спасибо^1, Крис.../%",
 "scr_text_slash_scr_text_gml_7070_0": "\\EB* ..^1. а-а? Что ты сказал?/",
 "scr_text_slash_scr_text_gml_7071_0": "\\E2* Н-но^1, м..^1. мыши.../",
 "scr_text_slash_scr_text_gml_7072_0": "\\C2 ",
 "scr_text_slash_scr_text_gml_7082_0": "\\E3* С-спасибо^1, Крис.../%",
 "scr_text_slash_scr_text_gml_7090_0": "\\EB* ..^1. я..^1. я.../",
 "scr_text_slash_scr_text_gml_7091_0": "\\EB* .../%",
 "scr_text_slash_scr_text_gml_7099_0": "#Давай решим#её вместе!",
 "scr_text_slash_scr_text_gml_7100_0": "#Продолжить",
 "scr_text_slash_scr_text_gml_7101_0": "",
 "scr_text_slash_scr_text_gml_7102_0": "",
 "scr_text_slash_scr_text_gml_7104_0": "\\E3* С..^1. смотри^1, Крис^1! Ещё одна головоломка!/",
 "scr_text_slash_scr_text_gml_7105_0": "\\C2 ",
 "scr_text_slash_scr_text_gml_7114_0": "\\E4* Д..^1. да^1, ты прав^1, Крис!/",
 "scr_text_slash_scr_text_gml_7115_0": "\\E3* (Мне казалось, Крис вёл себя странно^1, но...)/",
 "scr_text_slash_scr_text_gml_7116_0": "\\E2* (Наверное, это была просто очередная злая шутка...?)/%",
 "scr_text_slash_scr_text_gml_7153_0": "#Купить его",
 "scr_text_slash_scr_text_gml_7154_0": "#Обойдёмся",
 "scr_text_slash_scr_text_gml_7155_0": "",
 "scr_text_slash_scr_text_gml_7156_0": "",
 "scr_text_slash_scr_text_gml_7158_0": "\\E8* (Фаха^1, Крис покупает МНЕ кольцо...? Ага^1, конечно!)/",
 "scr_text_slash_scr_text_gml_7159_0": "\\C2 ",
 "scr_text_slash_scr_text_gml_7166_0": "#Купить его",
 "scr_text_slash_scr_text_gml_7167_0": "#Обойдёмся",
 "scr_text_slash_scr_text_gml_7168_0": "",
 "scr_text_slash_scr_text_gml_7169_0": "",
 "scr_text_slash_scr_text_gml_7176_0": "\\EF* А..^1. а? Крис^1, ты..^1. купишь его мне...?/",
 "scr_text_slash_scr_text_gml_7177_0": "\\E6* Ну^1, наверное..^1. можно и спросить о нём./"
