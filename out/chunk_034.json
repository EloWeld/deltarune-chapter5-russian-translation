 "scr_itemuse_slash_scr_itemuse_gml_42_0": "О, оно... липкое?",
 "scr_itemuse_slash_scr_itemuse_gml_65_0": "Мятки? Обожаю мятки!",
 "scr_itemuse_slash_scr_itemuse_gml_96_0": "С днём рождения! Хаха!",
 "scr_itemuse_slash_scr_itemuse_gml_112_0": "У меня глаза кружатся...",
 "scr_itemuse_slash_scr_itemuse_gml_132_0": "Э-это настоящее мясо...?",
 "scr_itemuse_slash_scr_itemuse_gml_151_0": "Эмм, что это? Милое...",
 "scr_itemuse_slash_scr_itemuse_gml_169_0": "Есть чем перекусить!",
 "scr_itemuse_slash_scr_itemuse_gml_179_0": "(Крис забрал две трети...)",
 "scr_itemuse_slash_scr_itemuse_gml_203_0": "Ммм... что!? Это кровь!?",
 "scr_itemuse_slash_scr_itemuse_gml_229_0": "Эмм, ничего, Крис, я поделюсь...",
 "scr_itemuse_slash_scr_itemuse_gml_247_0": "(А? Не знала, что Крису нравится этот вкус.)",
 "scr_itemuse_slash_scr_itemuse_gml_265_0": "На вкус как... скакалка?",
 "scr_itemuse_slash_scr_itemuse_gml_275_0": "Оно хрустит.",
 "scr_itemuse_slash_scr_itemuse_gml_279_0": "Как изящно!",
 "scr_itemuse_slash_scr_itemuse_gml_283_0": "Какая приятная песня...",
 "scr_itemuse_slash_scr_itemuse_gml_290_0": "* (Одежда приклеена к кукле...)/",
 "scr_itemuse_slash_scr_itemuse_gml_291_0": "* (Использовать это никак нельзя.)/%",
 "scr_itemuse_slash_scr_itemuse_gml_418_0": "Ну давай, дай остальное!",
 "scr_itemuse_slash_scr_itemuse_gml_422_0": "М-может, отдашь остальное Сьюзи?",
 "scr_itemuse_slash_scr_itemuse_gml_427_0": "Т... там ЕЩЁ!?",
 "scr_itemuse_slash_scr_itemuse_gml_438_0": "Эй, это круто!",
 "scr_itemuse_slash_scr_itemuse_gml_442_0": "Приятно меловое.",
 "scr_itemuse_slash_scr_itemuse_gml_446_0": "(Э-это не тот мел, что я ей дал?)",
 "scr_itemuse_slash_scr_itemuse_gml_456_0": "Как ты это, чёрт возьми, назвал!?",
 "scr_itemuse_slash_scr_itemuse_gml_460_0": "Это я сделал.",
 "scr_itemuse_slash_scr_itemuse_gml_464_0": "З-заморозка мозга! ... шучу!",
 "scr_itemuse_slash_scr_itemuse_gml_472_0": "Я это НЕ надену.",
 "scr_itemuse_slash_scr_itemuse_gml_473_0": "Как мило!",
 "scr_itemuse_slash_scr_itemuse_gml_474_0": "Напоминает один из моих свитеров.",
 "scr_itemuse_slash_scr_itemuse_gml_487_0": "Тут написано КИШКИ!",
 "scr_itemuse_slash_scr_itemuse_gml_491_0": "Тут написано Пушистик...",
 "scr_itemuse_slash_scr_itemuse_gml_495_0": "Я... я не могу прочесть эти символы...",
 "scr_itemuse_slash_scr_itemuse_gml_504_0": "* (Ты почувствовал напряжение.)/",
 "scr_itemuse_slash_scr_itemuse_gml_505_0": "* (... попробуй использовать в бою.)/%",
 "scr_itemuse_slash_scr_itemuse_gml_512_0": "* (Ты почувствовал напряжение.)/",
 "scr_itemuse_slash_scr_itemuse_gml_513_0": "* (... попробуй использовать в бою.)/%",
 "scr_itemuse_slash_scr_itemuse_gml_520_0": "* (Ты почувствовал напряжение.)/",
 "scr_itemuse_slash_scr_itemuse_gml_521_0": "* (... попробуй использовать в бою.)/%",
 "scr_itemuse_slash_scr_itemuse_gml_529_0": "Не сыпь на меня порошок!",
 "scr_itemuse_slash_scr_itemuse_gml_530_0": "Мятное!",
 "scr_itemuse_slash_scr_itemuse_gml_531_0": "Что ты посыпаешь?",
 "scr_itemuse_slash_scr_itemuse_gml_538_0": "Не кидай в меня мятки!",
 "scr_itemuse_slash_scr_itemuse_gml_539_0": "Мятное!",
 "scr_itemuse_slash_scr_itemuse_gml_540_0": "Что ты кидаешь?",
 "scr_itemuse_slash_scr_itemuse_gml_553_0": "Фу! ...а вкусно?",
