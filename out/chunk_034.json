 "scr_itemdesc_single_slash_scr_itemdesc_single_gml_54_0": "Бублик с зеркальной серединой.#Каждый укус звучит музыкой. +80ХП",
 "scr_itemdesc_single_slash_scr_itemdesc_single_gml_57_0": "Манекен с намертво#пришитой одеждой. Бесполезен",
